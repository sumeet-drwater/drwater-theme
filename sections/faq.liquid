{% comment %}
------------------------------------------------------------------------------
FAQ DROPDOWN SECTION (FINAL FIXED)
Left 50%: Heading (top) + Footer (bottom-aligned)
Right 50%: FAQ dropdowns (accordion)
Only one FAQ open at a time
------------------------------------------------------------------------------
{% endcomment %}

<section class="faq-section">
  <div class="faq-container">
    
    <!-- LEFT SIDE -->
    <div class="faq-left">
      <div class="faq-left-content">
        {% if section.settings.heading != blank %}
          <h2 class="faq-heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>

      <div class="faq-footer-box">
        {% if section.settings.footer_title != blank %}
          <h4 class="faq-footer-title">{{ section.settings.footer_title }}</h4>
        {% endif %}
        {% if section.settings.footer_text != blank %}
          <p class="faq-footer-text">{{ section.settings.footer_text }}</p>
        {% endif %}
        {% if section.settings.footer_button_text != blank %}
          <a href="{{ section.settings.footer_button_link }}" class="faq-btn">
            {{ section.settings.footer_button_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="faq-right">
      {% for block in section.blocks %}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-question">
            <span>{{ block.settings.question }}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
           <div class="faq-answer-content">
  {{ block.settings.answer }}
</div>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
/* ===== Layout ===== */
.faq-section {
  background: #fff;
  font-family: sans-serif;
  padding: 20px 20px;
}

.faq-container {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 60px;
  position: relative;
}

/* ===== Left Side ===== */
.faq-left {
  flex: 0 0 50%;
  max-width: 50%;
  display: flex;
  flex-direction: column;
  position: relative;
}

.faq-heading {
  font-size: 40px;
  font-weight: 550;
  color: #001a33;
  line-height: 1.3;
  margin-bottom: 20px;
}

/* Footer box pinned to bottom (desktop) */
.faq-footer-box {
  background: #f2f6fc;
  border-radius: 10px;
  padding: 25px;
  max-width: 420px;
  position: absolute;
  bottom: 0;
  left: 0;
}

.faq-footer-title {
  color: #001a33;
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 8px;
}

.faq-footer-text {
  font-size: 14px;
  color: #001a33;
  line-height: 1.5;
  margin-bottom: 16px;
}

.faq-btn {
  display: inline-block;
  background: #001a33;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  padding: 10px 22px;
  border-radius: 30px;
  text-decoration: none;
  transition: all 0.3s ease;
}
.faq-btn:hover { background: #0033a0; }

/* ===== Right Side ===== */
.faq-right {
  flex: 0 0 50%;
  max-width: 50%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.faq-item {
  background: #f7faff;
  border-radius: 10px;
  margin-bottom: 14px;
  overflow: hidden;
  transition: all 0.3s ease;
}

.faq-question {
  width: 100%;
  background: none;
  border: none;
  padding: 18px 20px;
  text-align: left;
  font-size: 16px;
  font-weight: 600;
  color: #051D60;
  cursor: pointer;
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background 0.3s ease;
    font-family: sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 550;
    line-height: 140%;
    letter-spacing: 0.14px;
    text-align: left;
}
.faq-question:hover {
  background: #e8f0ff;
}

.faq-icon {
  font-size: 20px;
    transition: transform 0.3s 
ease;
    color: white;
    background: blue;
    background: #0A195C;
    border-radius: 85px;
    display: flex
;
    width: 24px;
    height: 24px;
    justify-content: center;
    align-items: center;
    gap: 7.5px;
    flex-shrink: 0;
}
.faq-item.active .faq-icon {
  transform: rotate(45deg);
  color: #fff;
}

.faq-answer {
  display: none;
  padding: 16px 20px;
  background: #f7faff;
  color: #051D60;
  font-size: 14px;
  line-height: 1.6;
  border-radius: 0 0 10px 10px;
}

/* Active state */
.faq-item.active {
  background: #f7faff;
}
.faq-item.active .faq-question {
  color: #051D60;
}

/* ===== Responsive ===== */
@media (max-width: 992px) {
  .faq-container {
    flex-direction: column;
    gap: 10px;
  }

  .faq-left,
  .faq-right {
    flex: 0 0 100%;
    max-width: 100%;
    position: static;
  }

  .faq-heading {
    text-align: center;
    font-size: 30px;
  }

  /* Footer box moves below all FAQs */
  .faq-footer-box {
    position: static;
    margin: 0px auto 0;
    text-align: center;
    max-width: 90%;
    display: none;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const faqItems = document.querySelectorAll(".faq-item");

  faqItems.forEach((item) => {
    const question = item.querySelector(".faq-question");
    const answer = item.querySelector(".faq-answer");

    question.addEventListener("click", () => {
      // Close all others
      faqItems.forEach((other) => {
        if (other !== item) {
          other.classList.remove("active");
          other.querySelector(".faq-answer").style.display = "none";
        }
      });

      // Toggle current
      item.classList.toggle("active");
      answer.style.display = item.classList.contains("active") ? "block" : "none";
    });
  });
});
</script>

{% schema %}
{
  "name": "FAQ Dropdown Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Got Questions? We've Got Answers"
    },
    {
      "type": "text",
      "id": "footer_title",
      "label": "Footer Title",
      "default": "Didn't find the answer you're looking for?"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "We're here to help—reach out to our friendly team anytime for support and guidance."
    },
    {
      "type": "text",
      "id": "footer_button_text",
      "label": "Footer Button Text",
      "default": "Ask a Question"
    },
    {
      "type": "url",
      "id": "footer_button_link",
      "label": "Footer Button Link"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is a hydrogen water bottle and how does it work?"
        },
        {
  "type": "richtext",
  "id": "answer",
  "label": "Answer",
  "default": "<p>Hydrogen water bottles use electrolysis to infuse water with molecular hydrogen.</p>"
}
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Dropdown Section",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}