{% comment %}
------------------------------------------------------------------------------
CUSTOM REVIEW SLIDER WITH BADGE + BLOCKS
- Supports multiple reviews via blocks
- Desktop: 50/50 layout (image + text)
- Mobile: stacked (image first)
- Includes section heading & subheading
------------------------------------------------------------------------------
{% endcomment %}

 <section id="sksd-{{ section.id }}" class="sksd-review-slider">
  <!-- Section Heading -->
  <div class="sksd-header">
    {% if section.settings.heading != blank %}
      <h2 class="sksd-main-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="sksd-subheading">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <!-- Review Slides -->
  <div class="sksd-slides">
    {% for block in section.blocks %}
      <div class="sksd-slide {% if forloop.first %}active{% endif %}">
        <div class="sksd-left">
          {% if block.settings.badge_text != blank %}
            <div class="sksd-badge">
              {% for i in (1..block.settings.star_count) %}
                <span class="sksd-star">⭐</span>
              {% endfor %}
              <span class="sksd-badge-text">{{ block.settings.badge_text }}</span>
            </div>
          {% endif %}
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: '720x' }}" alt="{{ block.settings.heading | escape }}">
          {% endif %}
        </div>

        <div class="sksd-right">
          <span class="sksd-heading">{{ block.settings.heading }}</span>
          <p class="sksd-text">{{ block.settings.text }}</p>
          <span class="sksd-author">– {{ block.settings.author }}</span>
        </div>
      </div>
    {% endfor %}
  </div>

  <!-- Buttons -->
  <div class="sksd-btns">
    <button class="sksd-btn" id="sksd-prev-{{ section.id }}">← Prev</button>
    <button class="sksd-btn" id="sksd-next-{{ section.id }}">Next →</button>
  </div>
  <br>
</section>

<style>
  /* General Style */
  .sksd-review-slider {
    color: #fff;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Heading and Subheading */
  .sksd-header {
    margin-top: 0px;
    padding-top: 0px;
    text-align: center;
    margin-bottom: 40px;
  }

  .sksd-main-heading {
    margin-bottom: 6px;
    margin-top: 24px;
    color: var(--Deep-Blue, #041d60);
    font-size: 20px;
    font-weight: 500;
    line-height: 28px;
            font-family: var(--font-body);
        font-weight: 700;
        font-style: Bold;
        font-size: 34px;
        leading-trim: NONE;
        line-height: 40px;
        letter-spacing: 0px;
        text-align: center;
        color: rgba(4, 29, 96, 1);
  }

  .sksd-subheading {
    font-size: 16px;
    color: #444;
    line-height: 20px;

  }

  /* Review Slide */
  .sksd-slides {
    position: relative;
  }

  .sksd-slide {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .sksd-slide.active {
    display: flex;
  }

  .sksd-left {
    width: 450px;
    height: 448px;
    position: relative;
    background: #f0f0f0;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .sksd-left img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    border-radius: 16px;
  }

  .sksd-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background: #fff;
    color: #002060;
    padding: 6px 16px;
    border-radius: 40px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .sksd-star {
    color: gold;
    font-size: 16px;
  }

  .sksd-right {
    width: 450px;
    height: 448px;
    background: #002060;
    border-radius: 16px;
    padding: 28px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .sksd-right::before {
    content: "“";
    position: absolute;
    top: 25px;
    left: 30px;
    font-size: 80px;
    color: #fff;
    opacity: 0.2;
    font-family: serif;
    line-height: 0;
  }

  .sksd-heading {
    font-weight: 600;
    font-style: italic;
    margin-bottom: 6px;
    color: var(--color-white-solid, #FFF);
    font-size: 24px;
    line-height: 28px;
  }

  .sksd-text {
    color: var(--color-white-solid, #FFF);
    font-size: 16px;
    line-height: 24px;
    margin-bottom: 0px;
  }

  .sksd-author {
    color: var(--color-white-solid, #6796d6);
    font-size: 24px;
    font-weight: 550;
    line-height: 30px;
          margin-top: 14px;

  }

  .sksd-btns {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 20px;
  }

  .sksd-btn {
    background: #041d60;
    border: none;
    color: #fff;
    padding: 10px 25px;
    border-radius: 30px;
    cursor: pointer;
    font-weight: 600;
    transition: background 0.3s ease;
  }

  .sksd-btn:hover {
    background: #041d60;
  }

  @media (max-width: 768px) {
    .sksd-slide {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .sksd-left {
      width: 100%;
      height: auto;
    }

    .sksd-right {
      width: 100%;
      height: auto;
      padding: 25px;
    }

    .sksd-right::before {
      top: 10px;
      left: 15px;
      font-size: 60px;
    }

    .sksd-heading {
      margin-top: 14px;
      font-size: 24px;
            margin-bottom: 14px;

    }

    .sksd-text {
      font-size: 24px;
    }

    .sksd-author {
      font-size: 24px;
    }

    .sksd-badge {
      display: none;  /* Hide badge on mobile */
    }
  }
</style>

<script>
  (function () {
    const section = document.querySelector("#sksd-{{ section.id }}");
    const slides = section.querySelectorAll(".sksd-slide");
    const prev = document.getElementById("sksd-prev-{{ section.id }}");
    const next = document.getElementById("sksd-next-{{ section.id }}");
    let current = 0;

    function showSlide(i) {
      slides.forEach((s) => s.classList.remove("active"));
      slides[i].classList.add("active");
    }

    prev?.addEventListener("click", () => {
      current = (current - 1 + slides.length) % slides.length;
      showSlide(current);
    });

    next?.addEventListener("click", () => {
      current = (current + 1) % slides.length;
      showSlide(current);
    });
  })();
</script>

</section>

{% schema %}
{
  "name": "Review Slider + Blocks",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Trusted by thousands of happy customers around the world."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Block",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Review Image" },
        { "type": "text", "id": "heading", "label": "Review Heading", "default": "Game changer" },
        { "type": "textarea", "id": "text", "label": "Review Text", "default": "The bottle keeps my water fresh all day. Easy to carry and totally worth it!" },
        { "type": "text", "id": "author", "label": "Author Name", "default": "Nisha" },
        { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "71,571+ Happy Customers" },
        { "type": "range", "id": "star_count", "label": "Number of Stars", "min": 1, "max": 5, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Slider + Blocks",
      "category": "Testimonials"
    }
  ]
}
{% endschema %}