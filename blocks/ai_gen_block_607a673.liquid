{% doc %}
  @prompt
    A section to shoccase 3 9:16 product videos with text chips on the bottom left of each. max width of the section 1200 on web. 3 videos on web. on mobile: 1 video in the center, 1 on left and right blurred out & smalelr (scroll to view) , perfect chip colour have to be reverse. Black text (non bold, weight 400) on white chip, autoplay + looping on for videos. video controls hidden. mobile drag to scrll through videos
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-showcase-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-video-showcase-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .ai-video-showcase-item-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 9 / 16;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .ai-video-showcase-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-showcase-video-{{ ai_gen_id }}::-webkit-media-controls {
    display: none;
  }

  .ai-video-showcase-video-{{ ai_gen_id }}::-webkit-media-controls-enclosure {
    display: none;
  }

  .ai-video-showcase-chip-{{ ai_gen_id }} {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background-color: {{ block.settings.chip_background_color }};
    color: {{ block.settings.chip_text_color }};
    padding: 8px 16px;
    border-radius: {{ block.settings.chip_border_radius }}px;
    font-size: 14px;
    font-weight: 400;
    z-index: 2;
  }

  .ai-video-showcase-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-showcase-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-video-showcase-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-video-showcase-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 16px;
      padding: 0 20px;
      margin: 0 -20px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .ai-video-showcase-grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-video-showcase-item-{{ ai_gen_id }} {
      flex-shrink: 0;
      scroll-snap-align: center;
      width: 70%;
      transition: transform 0.3s ease, filter 0.3s ease, opacity 0.3s ease;
    }

    .ai-video-showcase-item-{{ ai_gen_id }}.ai-video-showcase-side-{{ ai_gen_id }} {
      transform: scale(0.85);
      filter: blur(4px);
      opacity: 0.6;
    }

    .ai-video-showcase-chip-{{ ai_gen_id }} {
      bottom: 12px;
      left: 12px;
      padding: 6px 12px;
      font-size: 12px;
    }
  }
{% endstyle %}

<video-showcase-{{ ai_gen_id }}
  class="ai-video-showcase-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-showcase-container-{{ ai_gen_id }}">
    <div class="ai-video-showcase-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign chip_key = 'chip_text_' | append: i
          assign video = block.settings[video_key]
          assign chip_text = block.settings[chip_key]
        %}

        <div
          class="ai-video-showcase-item-{{ ai_gen_id }}"
          data-video-index="{{ i }}"
        >
          {% if video %}
            <video
              class="ai-video-showcase-video-{{ ai_gen_id }}"
              src="{{ video.sources[1].url }}"
              playsinline
              muted
              loop
              autoplay
              disablepictureinpicture
              controlslist="nodownload nofullscreen noremoteplayback"
            ></video>
          {% else %}
            <div class="ai-video-showcase-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-video-showcase-empty-state-{{ ai_gen_id }}">
                Add video {{ i }}
              </div>
            </div>
          {% endif %}

          {% if chip_text != blank %}
            <div class="ai-video-showcase-chip-{{ ai_gen_id }}">
              {{ chip_text }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</video-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMobileScroll();
        this.hideVideoControls();
      }

      hideVideoControls() {
        const videos = this.querySelectorAll('.ai-video-showcase-video-{{ ai_gen_id }}');
        videos.forEach((video) => {
          video.removeAttribute('controls');
          video.addEventListener('contextmenu', (e) => e.preventDefault());
        });
      }

      setupMobileScroll() {
        if (window.innerWidth > 749) return;

        const grid = this.querySelector('.ai-video-showcase-grid-{{ ai_gen_id }}');
        const items = this.querySelectorAll('.ai-video-showcase-item-{{ ai_gen_id }}');

        if (!grid || items.length === 0) return;

        const updateActiveItem = () => {
          const gridRect = grid.getBoundingClientRect();
          const centerX = gridRect.left + gridRect.width / 2;

          items.forEach((item) => {
            const itemRect = item.getBoundingClientRect();
            const itemCenterX = itemRect.left + itemRect.width / 2;
            const distance = Math.abs(centerX - itemCenterX);

            if (distance < itemRect.width / 2) {
              item.classList.remove('ai-video-showcase-side-{{ ai_gen_id }}');
            } else {
              item.classList.add('ai-video-showcase-side-{{ ai_gen_id }}');
            }
          });
        };

        grid.addEventListener('scroll', updateActiveItem);
        updateActiveItem();

        window.addEventListener('resize', () => {
          if (window.innerWidth > 749) {
            items.forEach((item) => {
              item.classList.remove('ai-video-showcase-side-{{ ai_gen_id }}');
            });
          } else {
            updateActiveItem();
          }
        });
      }
    }

    customElements.define('video-showcase-{{ ai_gen_id }}', VideoShowcase{{ ai_gen_id }});
  })();
</script>

