{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding: {{ block.settings.padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-countdown-timer__container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.gap }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0;
    font-family: var(--font-heading-family);
    line-height: 1;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.unit_gap }}px;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-countdown-timer__value-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
    font-family: var(--font-heading-family);
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    color: {{ block.settings.label_color }};
    font-family: var(--font-heading-family);
    line-height: 1;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.expired_color }};
    font-size: {{ block.settings.expired_size }}px;
    font-weight: 600;
    font-family: var(--font-heading-family);
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-countdown-timer__value-{{ ai_gen_id }},
    .ai-countdown-timer__label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.7);
    }

    .ai-countdown-timer__container-{{ ai_gen_id }} {
      gap: calc({{ block.settings.gap }}px * 0.7);
    }

    .ai-countdown-timer__display-{{ ai_gen_id }} {
      gap: calc({{ block.settings.unit_gap }}px * 0.7);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-timer__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-countdown-timer__display-{{ ai_gen_id }}">
      {% if block.settings.show_days %}
        <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
          <span class="ai-countdown-timer__value-{{ ai_gen_id }}" data-days>00</span>
          <span class="ai-countdown-timer__label-{{ ai_gen_id }}">D:</span>
        </div>
      {% endif %}

      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <span class="ai-countdown-timer__value-{{ ai_gen_id }}" data-hours>00</span>
        <span class="ai-countdown-timer__label-{{ ai_gen_id }}">H:</span>
      </div>

      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <span class="ai-countdown-timer__value-{{ ai_gen_id }}" data-minutes>00</span>
        <span class="ai-countdown-timer__label-{{ ai_gen_id }}">M:</span>
      </div>

      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <span class="ai-countdown-timer__value-{{ ai_gen_id }}" data-seconds>00</span>
        <span class="ai-countdown-timer__label-{{ ai_gen_id }}">S</span>
      </div>
    </div>

    <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" data-expired style="display: none;">
      {{ block.settings.expired_message }}
    </div>
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.interval = null;
      }

      connectedCallback() {
        this.daysElement = this.querySelector('[data-days]');
        this.hoursElement = this.querySelector('[data-hours]');
        this.minutesElement = this.querySelector('[data-minutes]');
        this.secondsElement = this.querySelector('[data-seconds]');
        this.expiredElement = this.querySelector('[data-expired]');
        this.displayElement = this.querySelector('.ai-countdown-timer__display-{{ ai_gen_id }}');

        if (this.endDate && this.endTime) {
          this.startCountdown();
        }
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const endDateTime = new Date(this.endDate + 'T' + this.endTime).getTime();
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          clearInterval(this.interval);
          this.displayElement.style.display = 'none';
          this.expiredElement.style.display = 'block';
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysElement) {
          this.daysElement.textContent = this.padZero(days);
        }
        this.hoursElement.textContent = this.padZero(hours);
        this.minutesElement.textContent = this.padZero(minutes);
        this.secondsElement.textContent = this.padZero(seconds);
      }

      padZero(num) {
        return num.toString().padStart(2, '0');
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

