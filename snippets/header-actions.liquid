<script
  type="module"
  src="{{ 'cart-icon.js' | asset_url }}"
  fetchpriority="low"
></script>

{% capture cart_icon %}
  <cart-icon
    class="
      header-actions__cart-icon
      {% unless cart == empty %} header-actions__cart-icon--has-cart{% endunless %}
    "
    data-testid="cart-icon"
  >
    <span
      class="svg-wrapper"
      aria-hidden="true"
    >
      {{ 'icon-cart.svg' | inline_asset_content }}
    </span>

    {% render 'cart-bubble', limit: 100, live_region: true, test_id: test_id %}
  </cart-icon>
{% endcapture %}

<header-actions
  {{- block.shopify_attributes -}}
>
  {% if shop.customer_accounts_enabled %}
    <script
      src="{{ 'dialog.js' | asset_url }}"
      type="module"
    ></script>

    <anchored-popover-component
      data-close-on-resize="true"
      class="account-popover mobile:hidden"
    >
      {% render 'account-button' with 'account-popover' as popover_id %}
      <div
        class="account-popover__panel details-content color-{{ settings.popover_color_scheme }}"
        id="account-popover"
        popover="auto"
        ref="popover"
      >
        {%- comment -%}[2026-03-17] A11y: pass unique heading_id — this snippet renders twice, causing duplicate IDs{%- endcomment -%}
        {% render 'account-actions', heading_id: 'account-popover-heading' %}
      </div>
    </anchored-popover-component>

    <dialog-component
      class="account-drawer"
      {{ block.shopify_attributes }}
    >
      {% render 'account-button', attributes: 'on:click="/showDialog"' %}
      <dialog
        ref="dialog"
        class="color-{{ settings.popover_color_scheme }} dialog-modal dialog-drawer dialog-bottom-sheet account-drawer__dialog"
        scroll-lock
        aria-labelledby="account-drawer-heading"
      >
        <button
          ref="closeButton"
          on:click="/closeDialog"
          class="button button-unstyled close-button account-drawer__close-button"
          aria-label="{{ 'actions.close_dialog' | t }}"
          autofocus
        >
          <span
            class="svg-wrapper"
            aria-hidden="true"
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
        {%- comment -%}[2026-03-17] A11y: dialog render keeps default 'account-drawer-heading' matched by aria-labelledby above{%- endcomment -%}
        {% render 'account-actions', heading_id: 'account-drawer-heading' %}
      </dialog>
    </dialog-component>
  {% endif %}

  {% if settings.cart_type == 'drawer' and template.name != 'cart' %}
    <script
      src="{{ 'cart-drawer.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>

    <cart-drawer-component
      class="cart-drawer"
      {{ block.shopify_attributes }}
      {% if settings.auto_open_cart_drawer %}
        auto-open
      {% endif %}
    >
      <button
        class="button header-actions__action button-unstyled"
        on:click="/open"
        aria-haspopup="dialog"
        aria-label="{{ 'accessibility.cart' | t }}"
        aria-describedby="cart-bubble-text"
        data-testid="cart-drawer-trigger"
      >
        {{ cart_icon }}
      </button>

      <dialog
        ref="dialog"
        class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
        aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
        scroll-lock
        cart-summary-sticky="true"
      >
        <div class="cart-drawer__inner">
          <cart-items-component
            class="cart-items-component"
            data-section-id="{{ section.id }}"
          >
            {%- if cart.empty? or cart.total_price == 0 -%}
              <div class="cart-drawer__header">
                <button
                  ref="closeButton"
                  on:click="cart-drawer-component/close"
                  class="button close-button cart-drawer__close-button button-unstyled"
                  aria-label="{{ 'actions.close_dialog' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-close.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>


              <div
                class="cart-drawer__content motion-reduce"
                aria-label="{{ 'accessibility.cart' | t }}"
              >
                <h2
                  class="cart-drawer__heading h4 cart-drawer__heading--empty"
                  id="cart-drawer-heading-empty"
                >
                  {{ 'content.your_cart_is_empty' | t }}
                </h2>

                <div class="cart-drawer__items">
                  {% render 'cart-products', drawer_context: 'drawer' %}
                </div>
              </div>
            {%- else -%}
              {% comment %}  {% endcomment %}
{%- assign total_savings = 0 -%}
{%- comment -%} Cart-level discount codes (e.g. PITCHER15), excluding HYDRATEFIRST {%- endcomment -%}
{%- for discount in cart.cart_level_discount_applications -%}
  {%- unless discount.title == 'HYDRATEFIRST' -%}
    {%- assign total_savings = total_savings | plus: discount.total_allocated_amount -%}
  {%- endunless -%}
{%- endfor -%}
{%- comment -%}
  Per-item savings: use compare_at_price vs final price so the full markdown
  is shown (e.g. $200 compare_at → $109.99 final = $90 savings).
  item.price already reflects any automatic line-level discounts, so no
  double-counting. Fall back to line_level_discount_allocations only for
  items that have no compare_at markup.
{%- endcomment -%}
{%- for item in cart.items -%}
  {%- if item.compare_at_price > item.price -%}
    {%- assign item_savings = item.compare_at_price | minus: item.price -%}
    {%- assign item_savings = item_savings | times: item.quantity -%}
    {%- assign total_savings = total_savings | plus: item_savings -%}
  {%- else -%}
    {%- for alloc in item.line_level_discount_allocations -%}
      {%- assign total_savings = total_savings | plus: alloc.amount -%}
    {%- endfor -%}
  {%- endif -%}
{%- endfor -%}

{%- if total_savings > 0 -%}
  <div class="cart-savings-banner">
    <span class="cart-savings-banner__dot"></span>
    You're saving {{ total_savings | money }} on your
    {%- if customer == nil or customer.orders_count == 0 %} first{%- endif %} order
  </div>
{%- endif -%}
{% comment %}  {% endcomment %}
              <div
                class="cart-drawer__header"
                id="cart-drawer-header"
              >
                <h2
                  class="cart-drawer__heading h4"
                  id="cart-drawer-heading"
                >
                  {{ 'content.cart_title' | t }}
                  {% render 'cart-bubble' %}
                </h2>

                <button
                  ref="closeButton"
                  on:click="cart-drawer-component/close"
                  class="button close-button cart-drawer__close-button button-unstyled"
                  aria-label="{{ 'actions.close_dialog' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-close.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>
{% comment %}  {% endcomment %}



{%- assign tier1_threshold = 25000 -%}
{%- assign tier1_discount = 15 -%}
{%- assign tier2_threshold = 50000 -%}
{%- assign tier2_discount = 20 -%}
{%- assign cart_total = cart.original_total_price -%}
{%- if cart_total < tier1_threshold -%}
  {%- assign next_threshold = tier1_threshold -%}
  {%- assign next_discount = tier1_discount -%}
  {%- assign prev_threshold = 0 -%}
{%- elsif cart_total < tier2_threshold -%}
  {%- assign next_threshold = tier2_threshold -%}
  {%- assign next_discount = tier2_discount -%}
  {%- assign prev_threshold = tier1_threshold -%}
{%- else -%}
  {%- assign next_threshold = nil -%}
{%- endif -%}

{%- if next_threshold -%}
  {%- assign remaining = next_threshold | minus: cart_total -%}
  {%- assign range = next_threshold | minus: prev_threshold -%}
  {%- assign bar_progress = cart_total | minus: prev_threshold | times: 100 | divided_by: range -%}
  <div class="cart-progress">
    <p class="cart-progress__label">Add <strong>{{ remaining | money }}</strong> more to get <strong>{{ next_discount }}% off</strong></p>
    <div class="cart-progress__track">
      <div class="cart-progress__fill" style="width: {{ bar_progress }}%"></div>
    </div>
  </div>
{%- else -%}
  <div class="cart-progress">
    <p class="cart-progress__label">🎉 You've unlocked <strong>{{ tier2_discount }}% off</strong>!</p>
    <div class="cart-progress__track"><div class="cart-progress__fill" style="width:100%"></div></div>
  </div>
{%- endif -%}

{% comment %} {% render 'cart-summary' %} {% endcomment %}



              
              {% if settings.show_cart_header_offer and settings.cart_header_offer != blank %}
                  {% if customer == nil %}
                    <p class="cart_header_offer">
                      {{ settings.cart_header_offer }}
                    </p>
                  {% elsif customer.orders_count == 0 %}
                    <p class="cart_header_offer">
                      {{ settings.cart_header_offer }}
                    </p>
                  {% endif %}
              {% endif %}


                        

              
              {% if section.settings.free_gift_product %}
  
      {% if customer == nil %}
        <script>
          window.freeGiftVariant = {{ section.settings.free_gift_product.variants.first.id }};
        </script>

      {% elsif customer.orders_count == 0 %}
        <script>
          window.freeGiftVariant = {{ section.settings.free_gift_product.variants.first.id }};
        </script>

      {% endif %}

    {% endif %}

              <scroll-hint
                class="cart-drawer__content motion-reduce"
                aria-label="{{ 'accessibility.cart' | t }}"
                style="--header-height: 60px;"
              >
                <scroll-hint
                  class="cart-drawer__items"
                >
                  {% render 'cart-products', drawer_context: 'drawer' %}
              {% if settings.upsell_collection %}
  {% assign cart_product_ids = cart.items | map: 'product_id' %}

  <div class="cart_upsell">
    <div class="upsell_header">
    <h4>You may also like</h4> <a href="{{settings.upsell_collection.url }}">View All</a>
    </div>
    <div class="cart-upsell-grid">
      {% for product in settings.upsell_collection.products limit: 8 %}
        {% unless cart_product_ids contains product.id %}
          {% assign variant = product.selected_or_first_available_variant %}

          <div class="cart-upsell-item">
            <div class="upsell_cart_img">
            <img
              src="{{ product.featured_image | image_url: width: 300 }}"
              alt="{{ product.title }}"
              loading="lazy"
            >
            </div>
            <div class="cart-upsell-info">
          <a href="{{ product.url }}" class="cart-upsell-title">{{ product.title }}</a>

              <div class="cart-upsell-price">
                {% if variant.compare_at_price > variant.price %}
                  <span class="compare"><del>{{ variant.compare_at_price | money }}</del></span>
                  <span class="sale">{{ variant.price | money }}</span>
                {% else %}
                  <span>{{ variant.price | money }}</span>
                {% endif %}
              </div>

              <button
                class="button button--small upsell-add-to-cart"
                data-variant-id="{{ variant.id }}"
              >
                Add
              </button>
            </div>
          </div>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
{% endif %}


{% if settings.show_rating_badge %}

  <div class="rating-badge">

    {% if settings.customers_image != blank %}
      <div class="rating-image">
