{% comment %} Free Gift for 1st order {% endcomment %}
{% if settings.free_gift_product %}
  {% unless customer and customer.orders_count > 0 %}
    <script>
      document.addEventListener('DOMContentLoaded', async () => {
        const variantId = {{ settings.free_gift_product.variants.first.id | json }};
        if (!variantId) return;

        const cart = await fetch('/cart.js').then(r => r.json());
        const hasGift = cart.items.some(item => item.id === variantId);

        const giftRemoved = localStorage.getItem('freeGiftRemoved') === 'true';

        if (cart.item_count === 0) {
          localStorage.removeItem('freeGiftRemoved');
        }

        if (cart.item_count > 0 && !hasGift && !giftRemoved) {
          await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              id: variantId,
              quantity: 1
            })
          });

          window.location.reload();
        }

        if (!hasGift && cart.item_count > 0 && localStorage.getItem('giftWasInCart')) {
          localStorage.setItem('freeGiftRemoved', 'true');
        }

        if (hasGift) {
          localStorage.setItem('giftWasInCart', 'true');
        }
      });
    </script>
  {% endunless %}
{% endif %}
