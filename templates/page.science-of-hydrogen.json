//         "custom_liquid": "<div class=\"dr-water-landing\">\n    <style>\n        /* Font Face Definition */\n        @font-face {\n            font-family: 'JUST Sans';\n            src: url('https://cdn.shopify.com/s/files/1/0671/4245/1372/files/JUST_Sans_Medium.woff2?v=1767008684') format('woff2');\n            font-weight: 500;\n            font-style: normal;\n            font-display: swap;\n        }\n\n        :root {\n            --primary-color: #142B77;\n            --secondary-color: #007E89;\n            --bg-dark: rgb(35, 31, 32);\n            --bg-darker: #1a1819;\n            --bg-light: rgb(242, 246, 248);\n            --text-white: #ffffff;\n            --text-dark: #231f20;\n            --font-main: 'JUST Sans', 'Inter', sans-serif;\n            --spacing-unit: 8px;\n            --container-width: 1200px;\n        }\n\n        /* Scoped Reset & Base Styles */\n        .dr-water-landing * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        .dr-water-landing {\n            font-family: var(--font-main);\n            color: var(--text-dark);\n            line-height: 1.6;\n            overflow-x: hidden;\n            width: 100%;\n        }\n\n        .dr-water-landing img {\n            max-width: 100%;\n            display: block;\n        }\n\n        .dr-water-landing h1, \n        .dr-water-landing h2, \n        .dr-water-landing h3, \n        .dr-water-landing h4 {\n            line-height: 1.2;\n            font-weight: 500;\n            margin-bottom: 20px;\n        }\n\n        .dr-water-landing .container {\n            max-width: var(--container-width);\n            margin: 0 auto;\n            padding: 0 20px;\n        }\n\n        /* Reusable Components */\n        .dr-water-landing .btn {\n            display: inline-block;\n            background-color: var(--primary-color);\n            color: white;\n            padding: 16px 36px;\n            text-decoration: none;\n            border-radius: 50px;\n            font-weight: 600;\n            transition: transform 0.2s, background-color 0.2s;\n            cursor: pointer;\n            border: none;\n            font-size: 1.1rem;\n        }\n\n        .dr-water-landing .btn:hover {\n            transform: translateY(-2px);\n            background-color: #0f1f5a;\n        }\n\n        .dr-water-landing .section-padding {\n            padding: 120px 0;\n        }\n\n        /* Content Wrapper / Read More Logic */\n        .dr-water-landing .content-wrapper {\n            max-height: 0;\n            overflow: hidden;\n            transition: max-height 0.5s ease-out, opacity 0.5s ease;\n            opacity: 0;\n        }\n        \n        .dr-water-landing .content-wrapper.expanded {\n            opacity: 1;\n        }\n\n        .dr-water-landing .read-more-btn {\n            background: transparent;\n            border: 1px solid var(--primary-color);\n            color: var(--primary-color);\n            padding: 10px 24px;\n            border-radius: 50px;\n            margin: 10px 0 20px;\n            cursor: pointer;\n            font-family: var(--font-main);\n            font-size: 0.95rem;\n            font-weight: 500;\n            transition: all 0.3s ease;\n            display: inline-block;\n        }\n\n        .dr-water-landing .read-more-btn:hover {\n            background-color: var(--primary-color);\n            color: white;\n            transform: translateY(-2px);\n        }\n\n        .dr-water-landing .dark-bg .read-more-btn {\n            border-color: rgba(255,255,255,0.4);\n            color: white;\n        }\n        \n        .dr-water-landing .dark-bg .read-more-btn:hover {\n            background-color: white;\n            color: var(--primary-color);\n            border-color: white;\n        }\n\n        /* Scrollytelling Animation Styles */\n        .dr-water-landing .reveal-word {\n            display: inline-block;\n            opacity: 0.15;\n            transform: translateY(15px);\n            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), color 0.5s ease;\n            will-change: opacity, transform;\n            margin-right: 0.25em; \n        }\n\n        .dr-water-landing .reveal-word.active {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        .dr-water-landing .content-wrapper.expanded .reveal-word {\n            opacity: 1;\n            transform: translateY(0);\n            color: inherit;\n        }\n\n        /* Context-aware highlighting */\n        .dr-water-landing .light-bg .reveal-word.active {\n            color: var(--primary-color);\n        }\n\n        .dr-water-landing .dark-bg .reveal-word.active {\n            color: white;\n        }\n\n        /* Fold Styles */\n        .dr-water-landing .hero {\n            background: linear-gradient(180deg, #FFFFFF 0%, #F2F6F8 100%);\n            min-height: 90vh;\n            display: flex;\n            align-items: center;\n            text-align: center;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .dr-water-landing .hero h1 { font-size: 4.5rem; color: var(--primary-color); position: relative; z-index: 1; }\n        .dr-water-landing .hero p { font-size: 1.5rem; color: #555; margin: 0 auto; max-width: 600px; position: relative; z-index: 1; }\n\n        .dr-water-landing .text-center-section { text-align: center; background-color: white; }\n        .dr-water-landing .text-center-wrapper { max-width: 800px; margin: 0 auto; }\n        .dr-water-landing .text-center-section h2 { font-size: 3rem; margin-bottom: 32px; color: var(--primary-color); }\n        .dr-water-landing .text-center-section p { font-size: 1.35rem; color: #444; line-height: 1.8; margin-bottom: 24px; }\n\n        .dr-water-landing .split-section { background-color: var(--bg-dark); color: white; border-bottom: 1px solid rgba(255,255,255,0.05); }\n        .dr-water-landing .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }\n        .dr-water-landing .split-content h2 { font-size: 2.8rem; margin-bottom: 40px; color: white; }\n        .dr-water-landing .split-content p { font-size: 1.25rem; margin-bottom: 30px; color: #ddd; padding-left: 20px; border-left: 2px solid rgba(255,255,255,0.2); }\n        .dr-water-landing .split-section.reversed .split-content { order: 2; }\n        .dr-water-landing .split-section.light-mode { background-color: var(--bg-light); color: var(--text-dark); }\n        .dr-water-landing .split-section.light-mode .split-content h2 { color: var(--primary-color); }\n        .dr-water-landing .split-section.light-mode .split-content p { color: #555; border-left-color: var(--primary-color); }\n\n        .dr-water-landing .cta-section { background-color: var(--primary-color); color: white; height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center; }\n        .dr-water-landing .cta-section h2 { font-size: 4rem; margin-bottom: 40px; }\n        .dr-water-landing .cta-section .btn { background-color: white; color: var(--primary-color); padding: 20px 60px; font-size: 1.2rem; }\n\n        @media (max-width: 900px) {\n            .dr-water-landing .split-grid { grid-template-columns: 1fr; gap: 40px; }\n            .dr-water-landing .split-section.reversed .split-content { order: initial; }\n        }\n    </style>\n\n    <!-- Content -->\n    <header class=\"hero light-bg section-padding\">\n        <div class=\"container\">\n            <h1 class=\"animate-text\">The smallest molecule.<br>The deepest impact.</h1>\n            <p class=\"animate-text\" style=\"font-weight:600; margin-top:20px;\">Hydrogen water by Dr Water.</p>\n        </div>\n    </header>\n\n    <section class=\"text-center-section light-bg section-padding\">\n        <div class=\"container text-center-wrapper\">\n            <h2 class=\"animate-text\">We’ve always trusted water.<br>We just didn’t know its full potential.</h2>\n            <button class=\"read-more-btn\">Read more</button>\n            <div class=\"content-wrapper\">\n                <p class=\"animate-text\">For centuries, we’ve looked at water as the source of life. But what if what we’ve always known was only part of the story? Science began to look more closely and found something extraordinary hidden in every drop.</p>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"split-section dark-bg section-padding\">\n        <div class=\"container split-grid\">\n            <div class=\"split-content\">\n                <h2 class=\"animate-text\">Then science looked deeper and found hydrogen waiting to be freed.</h2>\n                <button class=\"read-more-btn\">Read more</button>\n                <div class=\"content-wrapper qa-block\">\n                    <p class=\"animate-text\">In normal water (H₂O), hydrogen is bound to oxygen - silent, unseen, and inactive.</p>\n                    <p class=\"animate-text\">When released and infused back into water as molecular H₂, it transforms what hydration means.</p>\n                    <p class=\"animate-text\">Now, every sip carries active hydrogen that moves through your body, supporting your cells from within.</p>\n                </div>\n            </div>\n            <div class=\"split-image\">\n                <img src=\"https://echowater.com/cdn/shop/files/HydrogenAnimation_Frame1_Resized_f4fa84fb-6b78-481e-b5c4-ae85f4dba8e2_1_1.svg?v=1758764876&width=600\" alt=\"Molecule Diagram\">\n            </div>\n        </div>\n    </section>\n\n    <section class=\"split-section reversed dark-bg section-padding\" style=\"background-color: var(--bg-darker);\">\n        <div class=\"container split-grid\">\n            <div class=\"split-content\">\n                <h2 class=\"animate-text\">What hydrogen molecule does within the cells</h2>\n                <button class=\"read-more-btn\">Read more</button>\n                <div class=\"content-wrapper qa-block\">\n                    <p class=\"animate-text\">Every day, normal metabolism and environmental stress create unstable molecules known as free radicals.</p>\n                    <p class=\"animate-text\">When these free radicals accumulate, they contribute to oxidative stress that interferes with normal cellular function.</p>\n                    <p class=\"animate-text\">Molecular hydrogen, due to its size, moves easily through cell membranes and into areas other antioxidants may not reach.</p>\n                    <p class=\"animate-text\">There, it helps support antioxidant balance, allowing cells to function more efficiently and recover more naturally.</p>\n                </div>\n            </div>\n            <div class=\"split-image\">\n                <img src=\"https://echowater.com/cdn/shop/files/HydrogenAnimation_Frame2_Resized_53d15def-d61d-4600-9ba0-2700f00a7f2e_1.svg?v=1758765110&width=600\" alt=\"Cellular Interaction\">\n            </div>\n        </div>\n    </section>\n\n    <section class=\"text-center-section light-bg section-padding\">\n        <div class=\"container text-center-wrapper\">\n            <h2 class=\"animate-text\">This discovery that changed how we understand wellness.</h2>\n            <button class=\"read-more-btn\">Read more</button>\n            <div class=\"content-wrapper\">\n                <p class=\"animate-text\">Research from around the world began confirming what scientists first suspected: hydrogen does more than hydrate. It helps the body balance oxidative stress, supports recovery, and enhances energy metabolism.</p>\n                <p class=\"animate-text\">Over 1,500 studies later, the evidence is clear: the smallest molecule can have the biggest effect on how we feel, perform, and age.</p>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"split-section dark-bg section-padding\">\n        <div class=\"container split-grid\">\n            <div class=\"split-content\">\n                <h2 class=\"animate-text\">Dr Water turned that science into something you can hold.</h2>\n                <button class=\"read-more-btn\">Read more</button>\n                <div class=\"content-wrapper qa-block\">\n                    <p class=\"animate-text\">Hydrogen is fragile. It escapes easily. So we built a system that protects it.</p>\n                    <p class=\"animate-text\">Every bottle of Dr Water is crafted to keep hydrogen stable and active until the moment you open it.</p>\n                    <p class=\"animate-text\">Tested. Sealed. Verified. Because you deserve water that works as hard as you do.</p>\n                </div>\n            </div>\n            <div class=\"split-image\">\n                <img src=\"https://echowater.com/cdn/shop/files/HydrogenAnimation_Frame4_2.svg?v=1758757129&width=600\" alt=\"Dr Water Science\">\n            </div>\n        </div>\n    </section>\n\n    <section class=\"lifestyle-section light-bg section-padding\">\n        <div class=\"container text-center-wrapper\">\n            <h2 class=\"animate-text\">From the lab to your lifestyle, this is hydration, reinvented.</h2>\n            <button class=\"read-more-btn\">Read more</button>\n            <div class=\"content-wrapper\">\n                <p class=\"animate-text\">You don’t have to change your routine. Just your water. With every sip, you’re not only hydrating, you’re fueling your body with what it’s naturally designed to use: pure, free hydrogen.</p>\n                <p class=\"animate-text\" style=\"font-weight: 600; color: var(--primary-color);\">No additives. No trends. Just nature, refined by science.</p>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"split-section light-mode section-padding\" style=\"background-color: white;\">\n        <div class=\"container split-grid\">\n            <div class=\"split-content\">\n                <h2 class=\"animate-text\">The future of water isn’t coming. It’s already here.</h2>\n                <button class=\"read-more-btn\">Read more</button>\n                <div class=\"content-wrapper qa-block\">\n                    <p class=\"animate-text\">What started as a question became a discovery.</p>\n                    <p class=\"animate-text\">That discovery became a movement.</p>\n                    <p class=\"animate-text\">And now, it’s within your reach.</p>\n                </div>\n            </div>\n             <div class=\"split-content\">\n                 <h2 class=\"animate-text\" style=\"font-size: 2rem; color: var(--secondary-color);\">Dr. Water</h2>\n                 <p class=\"animate-text\">The next generation of hydration - powered by the smallest molecule on Earth.</p>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"cta-section\">\n        <div class=\"container\">\n            <h2 class=\"animate-text\">Drink with intention.<br>Live with clarity.</h2>\n            <a href=\"#\" class=\"btn\">Explore the System</a>\n        </div>\n    </section>\n</div>\n\n<script>\n    document.addEventListener(\"DOMContentLoaded\", function() {\n        const container = document.querySelector('.dr-water-landing');\n        if(!container) return;\n\n        // 1. Prepare Text\n        const animateElements = container.querySelectorAll('.animate-text');\n        \n        animateElements.forEach(el => {\n            const originalText = el.innerText;\n            if(!originalText.trim()) return;\n            const words = originalText.split(/(\\s+)/);\n            el.innerHTML = words.map(word => {\n                if (word.trim().length > 0) return `<span class=\"reveal-word\">${word}</span>`;\n                return word; \n            }).join('');\n        });\n\n        // 2. Read More Button Logic\n        container.querySelectorAll('.read-more-btn').forEach(btn => {\n            btn.addEventListener('click', function() {\n                const content = this.nextElementSibling;\n                if(!content) return;\n                content.classList.toggle('expanded');\n                if (content.classList.contains('expanded')) {\n                    this.textContent = 'Read Less';\n                    content.style.maxHeight = content.scrollHeight + \"px\";\n                    const words = content.querySelectorAll('.reveal-word');\n                    words.forEach(word => {\n                        word.classList.add('active');\n                        word.style.transitionDelay = '0s'; \n                    });\n                } else {\n                    this.textContent = 'Read More';\n                    content.style.maxHeight = 0;\n                }\n            });\n        });\n\n        // 3. Scroll Handler\n        function onScroll() {\n            const windowHeight = window.innerHeight;\n            const readingLine = windowHeight * 0.75;\n            const allWords = container.querySelectorAll('.reveal-word');\n\n            allWords.forEach(word => {\n                if(word.offsetParent === null) return; \n                const rect = word.getBoundingClientRect();\n                if (rect.top < readingLine) word.classList.add('active');\n                else word.classList.remove('active');\n            });\n        }\n\n        let ticking = false;\n        window.addEventListener('scroll', () => {\n            if(!ticking) {\n                window.requestAnimationFrame(() => {\n                    onScroll();\n                    ticking = false;\n                });\n                ticking = true;\n            }\n        });\n\n        setTimeout(onScroll, 100);\n    });\n</script>",
