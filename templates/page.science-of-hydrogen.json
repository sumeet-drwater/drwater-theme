        "custom_liquid": "<div class=\"dr-water-landing\"><style>@font-face{font-family:'JUST Sans';src:url('https://cdn.shopify.com/s/files/1/0671/4245/1372/files/JUST_Sans_Medium.woff2?v=1767008684') format('woff2');font-weight:500;font-style:normal;font-display:swap;}@font-face{font-family:'Anatoleum';src:url('https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Anatoleum.woff2?v=1767008684') format('woff2');font-weight:400;font-style:normal;font-display:swap;}:root{--primary-color:#142B77;--secondary-color:#007E89;--bg-dark:#000000;--bg-darker:#000000;--bg-light:rgb(242,246,248);--text-white:#ffffff;--text-dark:#000000;--font-body:'JUST Sans',sans-serif;--font-heading:'Anatoleum','JUST Sans',sans-serif;--spacing-unit:8px;--container-width:1200px;}.dr-water-landing *{margin:0;padding:0;box-sizing:border-box;}.dr-water-landing{font-family:var(--font-body);color:var(--text-dark);line-height:1.6;overflow-x:hidden;width:100%;}.dr-water-landing img{max-width:100%;display:block;}.dr-water-landing h1,.dr-water-landing h2,.dr-water-landing h3,.dr-water-landing h4{font-family:var(--font-heading);line-height:1.2;font-weight:400;margin-bottom:20px;}.dr-water-landing .container{max-width:var(--container-width);margin:0 auto;padding:0 20px;}.dr-water-landing .btn{display:inline-block;background-color:var(--primary-color);color:#fff;padding:16px 36px;text-decoration:none;border-radius:50px;font-weight:600;transition:transform .2s,background-color .2s;cursor:pointer;border:none;font-size:1.1rem;font-family:var(--font-body);}.dr-water-landing .btn:hover{transform:translateY(-2px);background-color:#0f1f5a;}.dr-water-landing .section-padding{padding:120px 0;}.dr-water-landing .content-wrapper{max-height:0;overflow:hidden;transition:max-height .5s ease-out,opacity .5s ease;opacity:0;}.dr-water-landing .content-wrapper.expanded{opacity:1;}.dr-water-landing .read-more-btn{background:transparent;border:1px solid var(--primary-color);color:var(--primary-color);padding:10px 24px;border-radius:50px;margin:10px 0 20px;cursor:pointer;font-family:var(--font-body);font-size:.95rem;font-weight:500;transition:all .3s ease;display:inline-block;}.dr-water-landing .read-more-btn:hover{background-color:var(--primary-color);color:#fff;transform:translateY(-2px);}.dr-water-landing .dark-bg .read-more-btn{border-color:rgba(255,255,255,.4);color:#fff;}.dr-water-landing .dark-bg .read-more-btn:hover{background-color:#fff;color:var(--primary-color);border-color:#fff;}.dr-water-landing .reveal-word{display:inline-block;opacity:.15;transform:translateY(15px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1),color .5s ease;will-change:opacity,transform;margin-right:.25em;}.dr-water-landing .reveal-word.active{opacity:1;transform:translateY(0);}.dr-water-landing .content-wrapper.expanded .reveal-word{opacity:1;transform:translateY(0);color:inherit;}.dr-water-landing .light-bg .reveal-word.active{color:var(--primary-color);}.dr-water-landing .dark-bg .reveal-word.active{color:#fff;}.dr-water-landing .hero{background:linear-gradient(180deg,#FFFFFF 0%,#F2F6F8 100%);min-height:90vh;display:flex;align-items:center;text-align:center;position:relative;overflow:hidden;}.dr-water-landing .hero h1{font-size:4.5rem;color:var(--primary-color);position:relative;z-index:1;font-family:var(--font-heading);font-weight:400;}.dr-water-landing .hero p{font-size:1.5rem;color:#555;margin:0 auto;max-width:600px;position:relative;z-index:1;font-family:var(--font-body);}.dr-water-landing .text-center-section{text-align:center;background-color:#fff;}.dr-water-landing .text-center-wrapper{max-width:800px;margin:0 auto;}.dr-water-landing .text-center-section h2{font-size:3rem;margin-bottom:32px;color:var(--primary-color);font-family:var(--font-heading);font-weight:400;}.dr-water-landing .text-center-section p{font-size:1.35rem;color:#444;line-height:1.8;margin-bottom:24px;font-family:var(--font-body);}.dr-water-landing .split-section{background-color:var(--bg-dark);color:#fff;border-bottom:1px solid rgba(255,255,255,.05);}.dr-water-landing .split-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}.dr-water-landing .split-content h2{font-size:2.8rem;margin-bottom:40px;color:#fff;font-family:var(--font-heading);font-weight:400;}.dr-water-landing .split-content p{font-size:1.25rem;margin-bottom:30px;color:#ddd;padding-left:20px;border-left:2px solid rgba(255,255,255,.2);font-family:var(--font-body);}.dr-water-landing .split-section.reversed .split-content{order:2;}.dr-water-landing .split-section.light-mode{background-color:var(--bg-light);color:var(--text-dark);}.dr-water-landing .split-section.light-mode .split-content h2{color:var(--primary-color);}.dr-water-landing .split-section.light-mode .split-content p{color:#555;border-left-color:var(--primary-color);}.dr-water-landing .cta-section{background-color:var(--primary-color);color:#fff;height:80vh;display:flex;align-items:center;justify-content:center;text-align:center;}.dr-water-landing .cta-section h2{font-size:4rem;margin-bottom:40px;font-family:var(--font-heading);font-weight:400;}.dr-water-landing .cta-section .btn{background-color:#fff;color:var(--primary-color);padding:20px 60px;font-size:1.2rem;}.dr-water-landing .lifestyle-section{background:#fff;}@media(max-width:900px){.dr-water-landing .split-grid{grid-template-columns:1fr;gap:40px;}.dr-water-landing .split-section.reversed .split-content{order:initial;}}</style><header class=\"hero light-bg section-padding\"><div class=\"container\"><h1 class=\"animate-text\">The smallest molecule.<br>The deepest impact.</h1><p class=\"animate-text\" style=\"font-weight:600;margin-top:20px;\">Hydrogen water by Dr Water.</p></div></header><section class=\"text-center-section light-bg section-padding\"><div class=\"container text-center-wrapper\"><h2 class=\"animate-text\">We’ve always trusted water.<br>We just didn’t know its full potential.</h2><button class=\"read-more-btn\">Read more</button><div class=\"content-wrapper\"><p class=\"animate-text\">For centuries, we’ve looked at water as the source of life. But what if what we’ve always known was only part of the story? Science began to look more closely and found something extraordinary hidden in every drop.</p></div></div></section><section class=\"split-section dark-bg section-padding\"><div class=\"container split-grid\"><div class=\"split-content\"><h2 class=\"animate-text\">Then science looked deeper and found hydrogen waiting to be freed.</h2><button class=\"read-more-btn\">Read more</button><div class=\"content-wrapper qa-block\"><p class=\"animate-text\">In normal water (H₂O), hydrogen is bound to oxygen - silent, unseen, and inactive.</p><p class=\"animate-text\">When released and infused back into water as molecular H₂, it transforms what hydration means.</p><p class=\"animate-text\">Now, every sip carries active hydrogen that moves through your body, supporting your cells from within.</p></div></div><div class=\"split-image\"><img src=\"https://cdn.shopify.com/s/files/1/0671/4245/1372/files/why-hydrogen-1.png?v=1771486780&width=600\" alt=\"Molecule Diagram\"></div></div></section><section class=\"split-section reversed dark-bg section-padding\" style=\"background-color: var(--bg-darker);\"><div class=\"container split-grid\"><div class=\"split-content\"><h2 class=\"animate-text\">What hydrogen molecule does within the cells</h2><button class=\"read-more-btn\">Read more</button><div class=\"content-wrapper qa-block\"><p class=\"animate-text\">Every day, normal metabolism and environmental stress create unstable molecules known as free radicals.</p><p class=\"animate-text\">When these free radicals accumulate, they contribute to oxidative stress that interferes with normal cellular function.</p><p class=\"animate-text\">Molecular hydrogen, due to its size, moves easily through cell membranes and into areas other antioxidants may not reach.</p><p class=\"animate-text\">There, it helps support antioxidant balance, allowing cells to function more efficiently and recover more naturally.</p></div></div><div class=\"split-image\"><img src=\"https://cdn.shopify.com/s/files/1/0671/4245/1372/files/why-hydrogen-2.png?v=1771486615&width=600\" alt=\"Cellular Interaction\"></div></div></section><section class=\"text-center-section light-bg section-padding\"><div class=\"container text-center-wrapper\"><h2 class=\"animate-text\">This discovery that changed how we understand wellness.</h2><button class=\"read-more-btn\">Read more</button><div class=\"content-wrapper\"><p class=\"animate-text\">Research from around the world began confirming what scientists first suspected: hydrogen does more than hydrate. It helps the body balance oxidative stress, supports recovery, and enhances energy metabolism.</p><p class=\"animate-text\">Over 1,500 studies later, the evidence is clear: the smallest molecule can have the biggest effect on how we feel, perform, and age.</p></div></div></section><section class=\"split-section dark-bg section-padding\"><div class=\"container split-grid\"><div class=\"split-content\"><h2 class=\"animate-text\">Dr Water turned that science into something you can hold.</h2><button class=\"read-more-btn\">Read more</button><div class=\"content-wrapper qa-block\"><p class=\"animate-text\">Hydrogen is fragile. It escapes easily. So we built a system that protects it.</p><p class=\"animate-text\">Every bottle of Dr Water is crafted to keep hydrogen stable and active until the moment you open it.</p><p class=\"animate-text\">Tested. Sealed. Verified. Because you deserve water that works as hard as you do.</p></div></div><div class=\"split-image\"><img src=\"https://cdn.shopify.com/s/files/1/0671/4245/1372/files/why-hydrogen-3.png?v=1771486535\" alt=\"Dr Water Science\"></div></div></section><section class=\"lifestyle-section light-bg section-padding\"><div class=\"container text-center-wrapper\"><h2 class=\"animate-text\">From the lab to your lifestyle, this is hydration, reinvented.</h2><button class=\"read-more-btn\">Read more</button><div class=\"content-wrapper\"><p class=\"animate-text\">You don’t have to change your routine. Just your water. With every sip, you’re not only hydrating, you’re fueling your body with what it’s naturally designed to use: pure, free hydrogen.</p><p class=\"animate-text\" style=\"font-weight: 600; color: var(--primary-color);\">No additives. No trends. Just nature, refined by science.</p></div></div></section><section class=\"split-section light-mode section-padding\" style=\"background-color: white;\"><div class=\"container split-grid\"><div class=\"split-content\"><h2 class=\"animate-text\">The future of water isn’t coming. It’s already here.</h2><button class=\"read-more-btn\">Read more</button><div class=\"content-wrapper qa-block\"><p class=\"animate-text\">What started as a question became a discovery.</p><p class=\"animate-text\">That discovery became a movement.</p><p class=\"animate-text\">And now, it’s within your reach.</p></div></div><div class=\"split-content\"><h2 class=\"animate-text\" style=\"font-size: 2rem; color: var(--secondary-color);\">Dr. Water</h2><p class=\"animate-text\">The next generation of hydration - powered by the smallest molecule on Earth.</p></div></div></section><section class=\"cta-section\"><div class=\"container\"><h2 class=\"animate-text\">Drink with intention.<br>Live with clarity.</h2><a href=\"#\" class=\"btn\">Explore the System</a></div></section></div><script>document.addEventListener(\"DOMContentLoaded\",function(){const container=document.querySelector('.dr-water-landing');if(!container)return;const animateElements=container.querySelectorAll('.animate-text');animateElements.forEach(el=>{const originalText=el.innerText;if(!originalText.trim())return;const words=originalText.split(/(\\s+)/);el.innerHTML=words.map(word=>{if(word.trim().length>0)return `<span class=\"reveal-word\">${word}</span>`;return word;}).join('');});container.querySelectorAll('.read-more-btn').forEach(btn=>{btn.addEventListener('click',function(){const content=this.nextElementSibling;if(!content)return;content.classList.toggle('expanded');if(content.classList.contains('expanded')){this.textContent='Read Less';content.style.maxHeight=content.scrollHeight+\"px\";const words=content.querySelectorAll('.reveal-word');words.forEach(word=>{word.classList.add('active');word.style.transitionDelay='0s';});}else{this.textContent='Read More';content.style.maxHeight=0;}});});function onScroll(){const windowHeight=window.innerHeight;const readingLine=windowHeight*0.75;const allWords=container.querySelectorAll('.reveal-word');allWords.forEach(word=>{if(word.offsetParent===null)return;const rect=word.getBoundingClientRect();if(rect.top<readingLine)word.classList.add('active');else word.classList.remove('active');});}let ticking=false;window.addEventListener('scroll',()=>{if(!ticking){window.requestAnimationFrame(()=>{onScroll();ticking=false;});ticking=true;}});setTimeout(onScroll,100);});</script>"
      }
    }
