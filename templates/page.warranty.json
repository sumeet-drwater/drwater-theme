rgin: 8px 0; text-align: left; }\n  .dw-warranty .product-extra-text9023 div::before { content: '•'; position: absolute; left: 0; top: 0; color: #023064; font-weight: 600; }\n\n  .dw-warranty .product-link-button9023 { display: inline-block; width: 160px; padding: 10px 0; background: #023064; color: #fff; text-align: center; text-decoration: none; border-radius: 45px; font-size: 16px; margin-bottom: 16px; transition: background 0.3s; font-family: var(--font-body--family, var(--font-body-family, inherit)); }\n  .dw-warranty .product-link-button9023:hover { background: #5175a3; }\n\n  .dw-warranty .nav-button { position: absolute; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border: none; border-radius: 50%; background: rgba(255,255,255,0.8); color: #023064; font-size: 24px; cursor: pointer; z-index: 10; display: none; }\n  @media (max-width: 1000px) { .dw-warranty .nav-button { display: flex; background: rgba(2,48,100,0.3); color: #fff; } .dw-warranty .nav-button.prev { left: 8px; } .dw-warranty .nav-button.next { right: 8px; } }\n\n  @media (max-width: 768px) {\n    .dw-warranty .container9023 { padding: 0 4px; }\n    .dw-warranty .carousel-track9023 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; overflow-x: visible; scroll-snap-type: none; padding: 8px 0; }\n    .dw-warranty .nav-button { display: none !important; }\n    .dw-warranty .product-card9023 { flex: none; max-width: none; width: 100%; padding: 8px; min-height: auto; justify-content: flex-start; }\n    .dw-warranty .product-image9023 { height: 170px; margin-top: 16px; padding: 8px; }\n    .dw-warranty .product-name9023 { font-size: 16px; margin: 6px 0 2px; font-weight: 700; }\n    .dw-warranty .product-pricing9023 { margin: 4px 0; }\n    .dw-warranty .current-price9023 { font-size: 18px; }\n    .dw-warranty .original-price9023 { font-size: 14px; }\n    .dw-warranty .product-extra-text9023 { font-size: 14px; line-height: 1.5; margin: 6px 0; }\n    .dw-warranty .product-extra-text9023 div { margin: 4px 0; }\n    .dw-warranty .product-link-button9023 { width: 100%; font-size: 16px; padding: 6px 0; }\n  }\n<\/style>\n\n<div class=\"dw-warranty\">\n  <div class=\"container9023\">\n    <div class=\"carousel-wrapper9023\">\n      <button class=\"nav-button prev\" id=\"prevBtn\">&#10094;<\/button>\n      <button class=\"nav-button next\" id=\"nextBtn\">&#10095;<\/button>\n\n      <div class=\"carousel-track9023\" id=\"carouselTrack9023\">\n        <div class=\"product-card9023\">\n          <div class=\"product-image9023\">\n            <a href=\"https:\/\/drwater.store\/products\/3-years-extended-warranty-for-hydrator-pro\">\n              <img src=\"https:\/\/drwater.store\/cdn\/shop\/files\/Extended_Warranty_Hydrator_Pro.jpg\" alt=\"Hydrator Pro\">\n            <\/a>\n          <\/div>\n          <div class=\"product-name9023\">Hydrator Pro<\/div>\n          <div class=\"product-pricing9023\"><span class=\"current-price9023\">At Just $29.99<\/span><\/div>\n          <div class=\"product-extra-text9023\"><div>Hassle-free claims<\/div><div>3-Year warranty<\/div><div>Priority support<\/div><\/div>\n          <a href=\"https:\/\/drwater.store\/products\/3-years-extended-warranty-for-hydrator-pro\" class=\"product-link-button9023\">Protect Now<\/a>\n        <\/div>\n\n        <div class=\"product-card9023\">\n          <div class=\"product-image9023\">\n            <a href=\"https:\/\/drwater.store\/products\/3-years-of-worry-free-hydration\">\n              <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0671\/4245\/1372\/files\/Extended_Warranty_Pitcher.jpg?v=1755103769\" alt=\"HydroPitcher 68 oz\">\n            <\/a>\n          <\/div>\n          <div class=\"product-name9023\">HydroPitcher 68 oz<\/div>\n          <div class=\"product-pricing9023\"><span class=\"current-price9023\">At Just $24.99<\/span><\/div>\n          <div class=\"product-extra-text9023\"><div>Hassle-free claims<\/div><div>3-Year warranty<\/div><div>Priority support<\/div><\/div>\n          <a href=\"https:\/\/drwater.store\/products\/3-years-of-worry-free-hydration\" class=\"product-link-button9023\">Protect Now<\/a>\n        <\/div>\n\n        <div class=\"product-card9023\">\n          <div class=\"product-image9023\">\n            <a href=\"https:\/\/drwater.store\/products\/3-years-extended-warranty-for-hydrostanley\">\n              <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0671\/4245\/1372\/files\/Extended_Warranty_Stanley.jpg?v=1755103769\" alt=\"HydroStanley 32 oz\">\n            <\/a>\n          <\/div>\n          <div class=\"product-name9023\">HydroStanley 32 oz<\/div>\n          <div class=\"product-pricing9023\"><span class=\"current-price9023\">At Just $29.99<\/span><\/div>\n          <div class=\"product-extra-text9023\"><div>Hassle-free claims<\/div><div>3-Year warranty<\/div><div>Priority support<\/div><\/div>\n          <a href=\"https:\/\/drwater.store\/products\/3-years-extended-warranty-for-hydrostanley\" class=\"product-link-button9023\">Protect Now<\/a>\n        <\/div>\n\n          <\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\n  (function() {\n    const track = document.getElementById('carouselTrack9023');\n    if (!track) return;\n\n    const slides = Array.from(track.children);\n    const prevBtn = document.getElementById('prevBtn');\n    const nextBtn = document.getElementById('nextBtn');\n    let scrollEnd;\n\n    function snapToClosest() {\n      const center = track.scrollLeft + track.clientWidth \/ 2;\n      let closest = { dist: Infinity, el: null };\n\n      slides.forEach(slide => {\n        const c = slide.offsetLeft + slide.clientWidth \/ 2;\n        const d = Math.abs(center - c);\n        if (d < closest.dist) closest = { dist: d, el: slide };\n      });\n\n      if (!closest.el) return;\n      const left = closest.el.offsetLeft - (track.clientWidth - closest.el.clientWidth) \/ 2;\n      track.scrollTo({ left, behavior: 'smooth' });\n    }\n\n    track.addEventListener('scroll', () => {\n      clearTimeout(scrollEnd);\n      scrollEnd = setTimeout(snapToClosest, 100);\n    });\n\n    function navigate(dir) {\n      const center = track.scrollLeft + track.clientWidth \/ 2;\n      let currentIndex = 0;\n      let minD = Infinity;\n\n      slides.forEach((slide, i) => {\n        const c = slide.offsetLeft + slide.clientWidth \/ 2;\n        const d = Math.abs(center - c);\n        if (d < minD) { minD = d; currentIndex = i; }\n      });\n\n      let newIndex = currentIndex + dir;\n      if (newIndex < 0) newIndex = slides.length - 1;\n      if (newIndex >= slides.length) newIndex = 0;\n\n      const target = slides[newIndex];\n      const left = target.offsetLeft - (track.clientWidth - target.clientWidth) \/ 2;\n      track.scrollTo({ left, behavior: 'smooth' });\n    }\n\n    if (prevBtn) prevBtn.addEventListener('click', () => navigate(-1));\n    if (nextBtn) nextBtn.addEventListener('click', () => navigate(1));\n  })();\n<\/script>"}},"custom_liquid_MzJw6T":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<div class=\"klaviyo-form-TNw5Tq\"><\/div>","color_scheme":""}},"rich_text_jFkdb9":{"type":"rich-text","blocks":{"heading_t9PT34":{"type":"heading","settings":{"heading":"<strong>What’s Covered<\/strong>","heading_size":"h1"}},"text_KjB9hb":{"type":"text","settings":{"text":"<p>Our Extended Warranty keeps your Dr. Water product protected well beyond the standard coverage. If it develops an issue under normal use, we’ll make it right.<\/p><ul><li>Leaks or seal problems<\/li><li>Cracked or broken glass<\/li><li>Hydrogen generation stops working<\/li><li>Battery or charging malfunctions<\/li><\/ul>"}}},"block_order":["heading_t9PT34","text_KjB9hb"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"left","content_alignment":"left","color_scheme":"","full_width":true,"padding_top":0,"padding_bottom":28}},"rich_text_WMpLTm":{"type":"rich-text","blocks