rgba(20,43,119,.18);box-shadow:0 10px 22px rgba(0,0,0,.06);transition:transform .18s ease,box-shadow .18s ease,background-color .18s ease;} .drw-life__cta:hover{transform:translateY(-2px);box-shadow:0 14px 28px rgba(0,0,0,.10);} .drw-life__grid{display:grid;grid-template-columns:1.15fr .85fr;gap:16px;align-items:stretch;} .drw-life__stack{display:grid;grid-template-columns:1fr;gap:16px;} .drw-life__row2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;} .drw-life__card{position:relative;border-radius:var(--radius);overflow:hidden;background:var(--tile);border:1px solid var(--stroke);box-shadow:var(--shadow);isolation:isolate;} .drw-life__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;transform:scale(1.02);transition:transform .35s cubic-bezier(.16,1,.3,1);} .drw-life__card:hover .drw-life__img{transform:scale(1.08);} .drw-life__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0) 40%,rgba(0,0,0,.58) 100%);z-index:1;} .drw-life__label{position:absolute;left:14px;bottom:14px;right:14px;z-index:2;display:flex;flex-direction:column;gap:6px;} .drw-life__pill{align-self:flex-start;display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.92);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.5);font-family:'JUST Sans',sans-serif;font-weight:800;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--primary);} .drw-life__text{margin:0;font-family:'JUST Sans',sans-serif;font-weight:600;font-size:14px;line-height:1.35;color:rgba(255,255,255,.92);max-width:44ch;} .drw-life__big{min-height:520px;} .drw-life__mid{min-height:252px;} .drw-life__small{min-height:260px;} .drw-life__hint{margin-top:14px;font-family:'JUST Sans',sans-serif;font-size:13px;color:rgba(0,0,0,.55);} .drw-life__hint b{color:var(--primary);} @media (max-width: 980px){.drw-life{padding:70px 14px 78px;}