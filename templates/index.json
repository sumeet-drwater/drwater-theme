    "drwater_quiz_section": {
      "type": "custom-liquid",
      "name": "Quiz CTA (Homepage)",
      "settings": {
        "custom_liquid": "<section class=\"drw-quiz\" aria-label=\"Find your perfect hydration match\"><style>\n  @font-face{font-family:'Anatoleum';font-weight:900;font-style:normal;font-display:swap;src:url('https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Anatoleum.woff2') format('woff2');}\n\n  .drw-quiz{--p:#142B77;--s:#076AC1;--a:#D6E264;--bg:#FFFFFF;--ink:#0B1020;--muted:rgba(11,16,32,.72);background:var(--bg);padding:90px 20px;text-align:center;}\n  .drw-quiz *{box-sizing:border-box;}\n\n  .drw-quiz__inner{max-width:900px;margin:0 auto;}\n\n  .drw-quiz__headline{font-family:'Anatoleum',var(--font-heading--family,var(--font-body-family,inherit));margin:0 0 18px;color:var(--p);font-weight:900;letter-spacing:-.02em;line-height:1.05;font-size:clamp(34px,4vw,60px);}\n\n  .drw-quiz__body{margin:0 auto 28px;color:var(--muted);font-size:17px;line-height:1.8;max-width:60ch;}\n\n  .drw-quiz__cta{display:inline-flex;align-items:center;justify-content:center;gap:10px;padding:16px 28px;border-radius:999px;text-decoration:none;font-weight:900;letter-spacing:.02em;font-size:15px;transition:transform .18s ease,box-shadow .18s ease,background .18s ease;background:var(--p);color:#fff;box-shadow:0 14px 32px rgba(20,43,119,.18);cursor:pointer;border:none;}\n\n  .drw-quiz__cta:hover{background:var(--s);transform:translateY(-2px);box-shadow:0 20px 40px rgba(7,106,193,.25);} \n\n  @media (max-width:920px){\n    .drw-quiz{padding:50px 14px;}\n    .drw-quiz__headline{font-size:clamp(28px,6vw,40px);}\n    .drw-quiz__body{font-size:14px;line-height:1.6;}\n  }\n</style>\n\n<div class=\"drw-quiz__inner\">\n  <h1 class=\"drw-quiz__headline\">Not sure which Dr.Water product is right for you?</h1>\n  <p class=\"drw-quiz__body\">Every lifestyle is different. Your hydration system should be too. Take our 60-second quiz and we’ll recommend the best fit based on your routine, recovery needs, and goals.</p>\n  <button class=\"drw-quiz__cta\" onclick=\"window.alia = window.alia || []; window.alia.push({ type: 'open', campaignID: 27321, ignoreTargeting: true });\">Take the Quiz →</button>\n</div>\n</section>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "drwater_problem_solution": {
      "type": "custom-liquid",
      "name": "Problem / Solution (Homepage)",
      "settings": {
        "custom_liquid": "<section class=\"drw-ps\" aria-label=\"Problem and solution\"><style>\n  @font-face{font-family:'Anatoleum';font-weight:900;font-style:normal;font-display:swap;src:url('https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Anatoleum.woff2') format('woff2');}\n  .drw-ps{--p:#142B77;--s:#076AC1;--a:#D6E264;--bg:#FFFFFF;--ink:#0B1020;--muted:rgba(11,16,32,.72);--line:rgba(20,43,119,.16);background:var(--bg);padding:74px 20px;}\n  .drw-ps *{box-sizing:border-box;}\n  .drw-ps{font-family:var(--font-body--family,var(--font-body-family,inherit));}\n  .drw-ps__headline{font-family:'Anatoleum',var(--font-heading--family,var(--font-heading-family,var(--font-body--family,var(--font-body-family,inherit))));margin:0 0 28px;color:var(--p);font-weight:900;letter-spacing:-.02em;line-height:1.05;font-size:clamp(30px,3.6vw,54px);}\n\n  .drw-ps__inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:72px;align-items:start;}\n\n  .drw-ps__block{padding:18px 18px 16px;border:1px solid var(--line);border-radius:18px;background:linear-gradient(180deg,rgba(7,106,193,.04),rgba(20,43,119,.02));margin-bottom:14px;}\n  .drw-ps__label{display:inline-flex;align-items:center;gap:10px;margin:0 0 10px;padding:8px 12px;border-radius:999px;font-size:12px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:var(--p);background:rgba(20,43,119,.06);}\n  .drw-ps__label-dot{width:8px;height:8px;border-radius:999px;background:var(--a);box-shadow:0 0 0 3px rgba(214,226,100,.22);}\n  .drw-ps__body{margin:0;color:var(--ink);font-size:15.5px;line-height:1.8;max-width:62ch;}\n  .drw-ps__beat{display:block;margin:0 0 8px;}\n  .drw-ps__u{font-weight:800;color:var(--p);text-decoration:underline;text-decoration-thickness:.12em;text-underline-offset:.22em;text-decoration-color:rgba(214,226,100,.9);}\n\n  .drw-ps__cta{display:inline-flex;align-items:center;justify-content:center;gap:8px;margin-top:18px;padding:14px 20px;border-radius:999px;text-decoration:none;font-weight:900;letter-spacing:.02em;font-size:14px;transition:transform .18s ease,box-shadow .18s ease,background .18s ease;background:var(--p);color:#fff;box-shadow:0 10px 22px rgba(20,43,119,.18);} \n  .drw-ps__cta:hover{background:var(--s);transform:translateY(-2px);box-shadow:0 16px 30px rgba(7,106,193,.22);} \n\n  .drw-ps__right{display:flex;flex-direction:column;gap:16px;}\n  .drw-ps__card{border:1px solid var(--line);border-radius:22x;background:#fff;overflow:hidden;box-shadow:0 12px 30px rgba(20,43,119,.08);}\n  .drw-ps__media{position:relative;background:radial-gradient(1200px 300px at 20% 0%, rgba(214,226,100,.55), rgba(255,255,255,0));padding:18px 18px 6px;}\n  .drw-ps__img{display:block;width:100%;height:auto;border-radius:18px;}\n  .drw-ps__results{padding:18px;display:flex;flex-direction:column;gap:12px;}\n  .drw-ps__result{display:grid;grid-template-columns:42px 1fr;gap:14px;align-items:center;padding:12px 12px;border-radius:16px;background:linear-gradient(180deg,rgba(20,43,119,.05),rgba(7,106,193,.03));border:1px solid rgba(20,43,119,.10);}\n  .drw-ps__icon{width:42px;height:42px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:var(--p);box-shadow:0 10px 18px rgba(20,43,119,.18);}\n  .drw-ps__icon svg{width:20px;height:20px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}\n  .drw-ps__result-text{margin:0;color:var(--ink);font-weight:950;letter-spacing:-.01em;line-height:1.2;font-size:clamp(15px,1.55vw,18px);text-transform:uppercase;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}\n\n@media (max-width:920px){.drw-ps{padding:36px 8px;}.drw-ps__inner{grid-template-columns:1fr;gap:16px;}.drw-ps__headline{line-height:1.02;}.drw-ps__body{max-width:100%;font-size:12.5px;line-height:1.35;}.drw-ps__block{padding:10px 10px 8px;margin-bottom:10px;}.drw-ps__result-text{line-height:1.1;}}\n</style>\n\n<div class=\"drw-ps__inner\">\n  <div class=\"drw-ps__left\">\n    <h2 class=\"drw-ps__headline\">Let&rsquo;s talk water</h2>\n\n    <div class=\"drw-ps__block\">\n      <p class=\"drw-ps__label\"><span class=\"drw-ps__label-dot\"></span>The Problem</p>\n      <p class=\"drw-ps__body\">\n        <span class=\"drw-ps__beat\">You drink water every day thinking it&rsquo;s enough. <span class=\"drw-ps__u\">It isn&rsquo;t.</span></span>\n        <span class=\"drw-ps__beat\">Every stressful day, every hour of screen time produces <span class=\"drw-ps__u\">oxidative damage</span> inside your cells. \n\nThis is the reason your body feels slower and harder to recover as the years go on.</span>\n        <span class=\"drw-ps__beat\"><span class=\"drw-ps__u\">Regular water does nothing</span> about it.</span>\n      </p>\n    </div>\n\n    <div class=\"drw-ps__block\">\n      <p class=\"drw-ps__label\"><span class=\"drw-ps__label-dot\"></span>The Solution</p>\n      <p class=\"drw-ps__body\">\n        <span class=\"drw-ps__beat\">Dr.Water infuses your water with <span class=\"drw-ps__u\">H₂</span> in <span class=\"drw-ps__u\">5 minutes</span>, small enough to enter your bloodstream directly to neutralise the oxidative stress that your body can&rsquo;t clear on its own.</span>\n      </p>\n    </div>\n\n    <a class=\"drw-ps__cta\" href=\"/products\">Shop Dr.Water <span aria-hidden=\"true\">→</span></a>\n  </div>\n\n  <div class=\"drw-ps__right\">\n    <div class=\"drw-ps__card\">\n      <div class=\"drw-ps__media\">\n        <img class=\"drw-ps__img\" src=\"https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Old__1.png?v=1771843023&width=600\" srcset=\"https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Old__1.png?v=1771843023&width=400 400w, https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Old__1.png?v=1771843023&width=600 600w, https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Old__1.png?v=1771843023&width=700 700w, https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Old__1.png?v=1771843023&width=1000 1000w\" sizes=\"(min-width: 750px) 48vw, 100vw\" width=\"600\" height=\"600\" alt=\"Dr. Water product\" loading=\"lazy\">\n      </div>\n      <div class=\"drw-ps__results\">\n        <div class=\"drw-ps__result\">\n          <div class=\"drw-ps__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M13 10V3L4 14h7v7l9-11h-7z\"/></svg></div>\n          <p class=\"drw-ps__result-text\">SAY GOODBYE TO THE <span class=\"drw-ps__u\">2PM CRASH.</span></p>\n        </div>\n        <div class=\"drw-ps__result\">\n          <div class=\"drw-ps__icon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"5\"/><path d=\"M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42\"/></svg></div>\n          <p class=\"drw-ps__result-text\">CLEARER SKIN. FASTER RECOVERY. <span class=\"drw-ps__u\">ENERGY THAT ACTUALLY HOLDS.</span></p>\n        </div>\n        <div class=\"drw-ps__result\">\n          <div class=\"drw-ps__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/></svg></div>\n          <p class=\"drw-ps__result-text\">FEWER ACHES, <span class=\"drw-ps__u\">MORE OF YOUR OLD SELF BACK.</span></p>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n</section>",
