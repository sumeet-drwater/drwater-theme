      "type": "custom-liquid",
      "name": "Why Hydrogen (Link CTA)",
      "settings": {
        "custom_liquid": "<div class=\"drw-why-link\"><style>@font-face{font-family:'JUST Sans';src:url('https://cdn.shopify.com/s/files/1/0671/4245/1372/files/JUST_Sans_Medium.woff2?v=1767008684') format('woff2');font-weight:500;font-style:normal;font-display:swap;}@font-face{font-family:'Anatoleum';src:url('https://cdn.shopify.com/s/files/1/0671/4245/1372/files/Anatoleum.woff2') format('woff2');font-weight:400;font-style:normal;font-display:swap;}.drw-why-link{--primary:#142B77;--ink:#ffffff;--muted:rgba(255,255,255,.78);--stroke:rgba(255,255,255,.12);--radius:18px;--shadow:0 18px 55px rgba(0,0,0,.35);font-family:'Anatoleum','JUST Sans',sans-serif;width:100%;background:radial-gradient(1200px 700px at 20% 10%,rgba(20,43,119,.35),transparent 55%),radial-gradient(900px 600px at 90% 30%,rgba(0,126,137,.22),transparent 55%),linear-gradient(180deg,#000 0%,#000 100%);color:var(--ink);padding:82px 16px 120px;box-sizing:border-box;overflow:hidden;position:relative;}.drw-why-link *{box-sizing:border-box;}.drw-why-link__wrap{max-width:1200px;margin:0 auto;padding:0 20px;display:grid;grid-template-columns:1.05fr .95fr;gap:34px;align-items:center;}.drw-why-link__eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:'JUST Sans',sans-serif;font-weight:600;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin:0 0 14px;}.drw-why-link__dot{width:8px;height:8px;border-radius:999px;background:linear-gradient(180deg,#D6E264,rgba(214,226,100,.65));box-shadow:0 0 0 6px rgba(214,226,100,.12);}.drw-why-link__title{margin:0;color:#fff;font-weight:400;line-height:1.06;font-size:58px;letter-spacing:-.02em;}.drw-why-link__sub{margin:14px 0 0;color:var(--muted);font-family:'JUST Sans',sans-serif;font-weight:500;font-size:18px;line-height:1.5;max-width:44ch;}.drw-why-link__actions{margin-top:26px;display:flex;gap:12px;flex-wrap:wrap;}.drw-why-link__btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;background:#fff;color:#0a1e63;text-decoration:none;border-radius:999px;padding:16px 30px;font-weight:700;font-size:16px;line-height:1;border:1px solid rgba(255,255,255,.15);cursor:pointer;font-family:'JUST Sans',sans-serif;transition:transform .18s ease,box-shadow .18s ease,background-color .18s ease;box-shadow:0 10px 24px rgba(0,0,0,.35);}.drw-why-link__btn:hover{transform:translateY(-2px);box-shadow:0 14px 34px rgba(0,0,0,.45);}.drw-why-link__btn:active{transform:translateY(0);}.drw-why-link__btn--ghost{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.25);box-shadow:none;font-weight:600;}.drw-why-link__btn--ghost:hover{background:rgba(255,255,255,.06);}.drw-why-link__media{position:relative;border-radius:var(--radius);border:1px solid rgba(255,255,255,.14);box-shadow:var(--shadow);overflow:hidden;transform:translateY(8px);opacity:0;animation:drwWhyIn .7s cubic-bezier(.16,1,.3,1) .05s forwards;background:#000;}.drw-why-link__media::before{content:\"\";position:absolute;inset:0;background:radial-gradient(600px 240px at 30% 10%,rgba(214,226,100,.14),transparent 60%),radial-gradient(540px 260px at 80% 30%,rgba(20,43,119,.18),transparent 60%);pointer-events:none;z-index:2;}.drw-why-link__imgWrap{position:relative;aspect-ratio:16/10;display:block;}.drw-why-link__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;transform:scale(1.02);transition:transform .25s ease;}.drw-why-link__media:hover .drw-why-link__img{transform:scale(1.06);}.drw-why-link__badge{position:absolute;left:14px;top:14px;display:inline-flex;align-items:center;gap:8px;padding:10px 12px;border-radius:999px;background:rgba(0,0,0,.55);border:1px solid rgba(255,255,255,.18);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);color:#fff;font-family:'JUST Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:.02em;z-index:3;}.drw-why-link__badge svg{width:16px;height:16px;opacity:.9;}.drw-why-link__caption{position:relative;padding:16px 18px 18px;border-top:1px solid rgba(255,255,255,.12);background:linear-gradient(180deg,rgba(0,0,0,.55),rgba(0,0,0,.25));z-index:3;}.drw-why-link__capTitle{margin:0 0 6px;font-family:'JUST Sans',sans-serif;font-size:14px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:rgba(255,255,255,.92);}.drw-why-link__capText{margin:0;font-family:'JUST Sans',sans-serif;font-size:14px;line-height:1.45;color:rgba(255,255,255,.78);}.drw-why-link__left{transform:translateY(8px);opacity:0;animation:drwWhyIn .7s cubic-bezier(.16,1,.3,1) 0s forwards;}@keyframes drwWhyIn{to{transform:translateY(0);opacity:1;}}@media (max-width: 980px){.drw-why-link{padding:64px 14px 98px;}.drw-why-link__wrap{grid-template-columns:1fr;gap:22px;}.drw-why-link__title{font-size:44px;}.drw-why-link__sub{font-size:16px;max-width:52ch;}}@media (max-width: 480px){.drw-why-link__title{font-size:34px;}.drw-why-link__actions{flex-direction:column;align-items:stretch;}.drw-why-link__btn{width:100%;}.drw-why-link__badge{left:12px;top:12px;}.drw-why-link__caption{padding:14px 14px 16px;}}</style><div class=\"drw-why-link__wrap\"><div class=\"drw-why-link__left\"><div class=\"drw-why-link__eyebrow\"><span class=\"drw-why-link__dot\"></span><span>WHY HYDROGEN</span></div><h2 class=\"drw-why-link__title\">The smallest molecule.<br>The deepest impact.</h2><p class=\"drw-why-link__sub\">How molecular hydrogen works inside the body and why it’s different from regular water.</p><div class=\"drw-why-link__actions\"><a class=\"drw-why-link__btn\" href=\"https://drwater.store/pages/why-hydrogen\" aria-label=\"Open Why Hydrogen page\">why hydrogen? <span aria-hidden=\"true\">→</span></a><a class=\"drw-why-link__btn drw-why-link__btn--ghost\" href=\"https://drwater.store/pages/why-hydrogen#science\" aria-label=\"Jump to the science section\">see the science</a></div></div><a class=\"drw-why-link__media\" href=\"https://drwater.store/pages/why-hydrogen\" aria-label=\"Why Hydrogen page\"><div class=\"drw-why-link__imgWrap\"><div class=\"drw-why-link__badge\"><svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 21s-7-4.35-7-11a7 7 0 0 1 14 0c0 6.65-7 11-7 11Z\" stroke=\"\" stroke-width=\"0\" stroke-linecap=\"\" stroke-linejoin=\"round\"/></svg><span></span></div><img class=\"drw-why-link__img\" src=\"https://cdn.shopify.com/s/files/1/0671/4245/1372/files/why-hydrogen-3.png?v=1771486535\" alt=\"Why Hydrogen preview image\" loading=\"lazy\"></div><div class=\"drw-why-link__caption\"><div class=\"drw-why-link__capTitle\">Know what you’re drinking</div><p class=\"drw-why-link__capText\">The core science behind hydrogen water.</p></div></a></div></div>",
