    "custom_liquid_TQAAzK": {
      "type": "custom-liquid",
      "name": "Compairons",
      "settings": {
        "custom_liquid": "<style>\n  /* ===========================\n     WHY DR. WATER TABLE (v2)\n     =========================== */\n  .drw-why-section {\n    color: #001B49;\n    background: #fff;\n    text-align: center;\n  }\n\n  .drw-why-section h2 {\n    font-size: 32px;\n    font-weight: 500;\n    color: #001B49;\n    margin-bottom: 30px;\n  }\n\n  .drw-comparison-table {\n    width: 100%;\n    max-width: 850px;\n    margin: 0 auto;\n    border-collapse: collapse;\n    border: 2px solid #001B49;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n\n  .drw-comparison-table th,\n  .drw-comparison-table td {\n    border: 1px solid #001B49;\n    padding: 20px 15px;\n    font-size: 16px;\n    vertical-align: middle;\n  }\n\n  .drw-comparison-table th {\n    font-weight: 500;\n    font-size: 18px;\n    color: #001B49;\n  }\n\n  .drw-comparison-table td:first-child {\n    font-weight: 500;\n    color: #001B49;\n    text-align: left;\n    width: 25%;\n  }\n\n  .drw-img-cell {\n    padding: 30px 15px;\n  }\n\n  .drw-img-cell img {\n    width: 150px;\n    height: auto;\n    border-radius: 6px;\n  }\n\n  .drw-blue {\n    background: #001B49;\n    color: #fff;\n    font-weight: 600;\n    text-align: center;\n  }\n\n  .drw-light-blue {\n    background: #EAF1FF;\n    color: #001B49;\n    font-weight: 600;\n    text-align: center;\n  }\n\n  @media (max-width: 768px) {\n    .drw-why-section h2 {\n      font-size: 26px;\n    }\n    .drw-comparison-table th,\n    .drw-comparison-table td {\n      font-size: 14px;\n      padding: 12px;\n    }\n    .drw-img-cell img {\n      width: 120px;\n    }\n  }\n</style>\n\n<section class=\"drw-why-section\">\n  <h2>Don't worry. You're getting the best filter.</h2>\n\n  <table class=\"drw-comparison-table\">\n    <tr>\n      <th></th>\n      <th>\n        <img src=\"https://cdn.shopify.com/s/files/1/0671/4245/1372/files/singlefilter.png?v=1769603388\" alt=\"Dr. Water\" style=\"width:48px;\">\n      </th>\n      <th>Others</th>\n    </tr>\n\n    <tr>\n      <td>Cost of Filterhead</td>\n      <td class=\"drw-light-blue\">$39</td>\n      <td>$89</td>\n    </tr>\n\n    <tr>\n      <td>Cost of Filter Replacements (every 6 months)</td>\n      <td class=\"drw-light-blue\">$39</td>\n      <td>$78</td>\n    </tr>\n\n    <tr>\n      <td>Safe to use in warm water.</td>\n      <td class=\"drw-blue\">✓</td>\n      <td>✕</td>\n    </tr>\n\n    <tr>\n      <td>Less likely to harbor bacterial growth.</td>\n      <td class=\"drw-blue\">✓</td>\n      <td>✕</td>\n    </tr>\n\n    <tr>\n      <td>Minimalist design.</td>\n      <td class=\"drw-blue\">✓</td>\n      <td>Big and Bulky</td>\n    </tr>\n\n    <tr>\n      <td>Made in South Korea.</td>\n      <td class=\"drw-blue\">✓</td>\n      <td>✕</td>\n    </tr>\n  </table>\n</section>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "custom_liquid_aE6pLW": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<section class=\"ps3\" id=\"ps3\" data-steps=\"4\">\n  <div class=\"ps3-wrap\">\n    <!-- Left sticky header -->\n    <div class=\"ps3-left\">\n      <div class=\"ps3-eyebrow\">SEE FOR YOURSELF.</div>\n      <h2 class=\"ps3-title\">Tap Water’s Dirty Little Secret.</h2>\n      <p class=\"ps3-sub\">Take a look at what the Watersoft filter caught in just one month.</p>\n\n      <div class=\"ps3-meter\" aria-hidden=\"true\">\n        <div class=\"ps3-dot active\" data-i=\"0\"></div>\n        <div class=\"ps3-dot\" data-i=\"1\"></div>\n        <div class=\"ps3-dot\" data-i=\"2\"></div>\n        <div class=\"ps3-dot\" data-i=\"3\"></div>\n      </div>\n    </div>\n\n    <!-- Right card stack -->\n    <div class=\"ps3-right\">\n      <div class=\"ps3-stack\" id=\"ps3-stack\">\n        <div class=\"ps3-card is-active\" data-i=\"0\">\n          <button class=\"ps3-head\" type=\"button\" aria-expanded=\"true\">\n            <div class=\"ps3-name\">Chlorine &amp; Chloramine</div>\n            <div class=\"ps3-pill\">Disinfectants</div>\n          </button>\n          <div class=\"ps3-body\">\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">EFFECTS ON SKIN</div>\n              <p>Strips skin of its natural oils, leaving them damaged, dry, and irritated.</p>\n            </div>\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">WHERE DOES IT COME FROM?</div>\n              <p>A disinfectant used to neutralize and prevent bacterial growth in your tap water.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"ps3-card\" data-i=\"1\">\n          <button class=\"ps3-head\" type=\"button\" aria-expanded=\"false\">\n            <div class=\"ps3-name\">Dirt &amp; Rust</div>\n            <div class=\"ps3-pill\">Pipe debris</div>\n          </button>\n          <div class=\"ps3-body\">\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">EFFECTS ON SKIN</div>\n              <p>Irritates sensitive skin and contributes to clogged pores.</p>\n            </div>\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">WHERE DOES IT COME FROM?</div>\n              <p>Old, aging water pipes flake off rust and other pipe materials into the water.</p>\n            </div>\n            <div class=\"ps3-source\">Source: Environmental Working Group (EWG)</div>\n          </div>\n        </div>\n\n        <div class=\"ps3-card\" data-i=\"2\">\n          <button class=\"ps3-head\" type=\"button\" aria-expanded=\"false\">\n            <div class=\"ps3-name\">Germs &amp; Bacteria</div>\n            <div class=\"ps3-pill\">Microbes</div>\n          </button>\n          <div class=\"ps3-body\">\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">EFFECTS ON SKIN</div>\n              <p>Aggravates itchy, red, or dry skin. Can infect open wounds.</p>\n            </div>\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">WHERE DOES IT COME FROM?</div>\n              <p>Germs can grow and multiply in the pipes inside a home or building if the conditions are right.</p>\n            </div>\n            <div class=\"ps3-source\">Source: Centers for Disease Control and Prevention (CDC)</div>\n          </div>\n        </div>\n\n        <div class=\"ps3-card\" data-i=\"3\">\n          <button class=\"ps3-head\" type=\"button\" aria-expanded=\"false\">\n            <div class=\"ps3-name\">Micro Plastics</div>\n            <div class=\"ps3-pill\">Plastic fragments</div>\n          </button>\n          <div class=\"ps3-body\">\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">EFFECTS ON SKIN</div>\n              <p>Seeps into open wounds and can cause micro-abrasions.</p>\n            </div>\n            <div class=\"ps3-block\">\n              <div class=\"ps3-kicker\">WHERE DOES IT COME FROM?</div>\n              <p>Plastic bottles and caps used in bottled water, plastic bags, and everyday plastic breakdown.</p>\n            </div>\n            <div class=\"ps3-source\">Source: World Health Organization (WHO)</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n  .ps3{\n    background:#fff;\n    font-family:\"JUST Sans\", sans-serif;\n    color:#001B49;\n    padding: 48px 16px;\n    margin: 0 !important;\n  }\n\n  .ps3-wrap{\n    max-width:1200px;\n    margin:0 auto;\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    gap: 18px;\n    align-items:start;\n  }\n\n  .ps3-left{\n    position: sticky;\n    top: 18px;\n    align-self:start;\n  }\n\n  .ps3-eyebrow{\n    font-size:12px;\n    letter-spacing:0.08em;\n    opacity:0.75;\n    margin-bottom:10px;\n    font-weight:600;\n  }\n  .ps3-title{\n    font-size:44px;\n    line-height:1.06;\n    margin:0 0 14px 0;\n    font-weight:600;\n  }\n  .ps3-sub{\n    margin:0 0 14px 0;\n    font-size:16px;\n    line-height:1.5;\n    opacity:0.9;\n    max-width:360px;\n    font-weight:400;\n  }\n\n  .ps3-meter{ display:flex; gap:8px; align-items:center; margin-top:10px; }\n  .ps3-dot{\n    width:10px; height:10px; border-radius:999px;\n    border:1px solid rgba(0,27,73,0.25);\n    background:transparent;\n    transition: transform 200ms ease, background 200ms ease, border-color 200ms ease;\n  }\n  .ps3-dot.active{\n    background:#001B49;\n    border-color:#001B49;\n    transform:scale(1.15);\n  }\n\n  .ps3-stack{\n    position: sticky;\n    top: 18px;\n    display:flex;\n    flex-direction:column;\n    gap: 10px;\n    margin: 0;\n    padding: 0;\n  }\n\n  .ps3-card{\n    border:1px solid rgba(0,27,73,0.14);\n    border-radius:16px;\n    background:#fff;\n    overflow:hidden;\n    box-shadow: 0 14px 40px rgba(0,0,0,0.06);\n    margin: 0;\n  }\n\n  .ps3-head{\n    width:100%;\n    border:0;\n    background: linear-gradient(180deg, rgba(0,27,73,0.04), rgba(255,255,255,0));\n    padding: 16px;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap: 12px;\n    cursor: pointer;\n    text-align:left;\n  }\n\n  .ps3-name{\n    font-size:18px;\n    line-height:1.2;\n    font-weight:600;\n    color:#001B49;\n  }\n  .ps3-pill{\n    font-size:12px;\n    padding:6px 10px;\n    border-radius:999px;\n    border:1px solid rgba(0,27,73,0.18);\n    background: rgba(0,27,73,0.03);\n    font-weight:600;\n    white-space:nowrap;\n    color:#001B49;\n  }\n\n  .ps3-body{\n    padding: 0 16px;\n    max-height: 0;\n    opacity: 0;\n    overflow:hidden;\n    transition: max-height 360ms ease, opacity 200ms ease, padding 200ms ease;\n  }\n  .ps3-card.is-active .ps3-body{\n    padding: 2px 16px 16px;\n    opacity: 1;\n  }\n\n  .ps3-block{ margin-top:12px; }\n  .ps3-kicker{\n    font-size:12px;\n    letter-spacing:0.08em;\n    opacity:0.75;\n    font-weight:600;\n    margin-bottom:6px;\n  }\n  .ps3-body p{\n    margin:0;\n    font-size:14px;\n    line-height:1.55;\n    color:#1d2b57;\n    font-weight:400;\n  }\n  .ps3-source{\n    margin-top:12px;\n    font-size:12px;\n    opacity:0.7;\n    font-weight:400;\n  }\n\n  @media (max-width: 980px){\n    .ps3-wrap{\n      grid-template-columns: 1fr;\n      gap: 14px;\n    }\n    .ps3-left{\n      position: relative;\n      top: 0;\n    }\n    .ps3-stack{\n      position: relative;\n      top: 0;\n    }\n    .ps3-title{ font-size:34px; }\n    .ps3-sub{ max-width: 100%; }\n  }\n</style>\n\n<script>\n  (function(){\n    var section = document.getElementById('ps3');\n    if(!section) return;\n\n    var stack = document.getElementById('ps3-stack');\n    if(!stack) return;\n\n    var cards = Array.prototype.slice.call(section.querySelectorAll('.ps3-card'));\n    var dots  = Array.prototype.slice.call(section.querySelectorAll('.ps3-dot'));\n    var steps = parseInt(section.getAttribute('data-steps'), 10) || cards.length;\n\n    function isDesktop(){\n      return window.matchMedia('(min-width: 981px)').matches;\n    }\n\n    function setDots(i){\n      dots.forEach(function(d){ d.classList.remove('active'); });\n      var dot = section.querySelector('.ps3-dot[data-i=\"'+i+'\"]');\n      if(dot) dot.classList.add('active');\n    }\n\n    function setActive(i){\n      cards.forEach(function(card, idx){\n        var body = card.querySelector('.ps3-body');\n        var head = card.querySelector('.ps3-head');\n\n        card.classList.toggle('is-active', idx === i);\n        if(head) head.setAttribute('aria-expanded', idx === i ? 'true' : 'false');\n\n        if(body){\n          if(idx === i){\n            body.style.maxHeight = body.scrollHeight + 'px';\n          } else {\n            body.style.maxHeight = '0px';\n          }\n        }\n      });\n      setDots(i);\n    }\n\n    // Click-to-toggle always works\n    cards.forEach(function(card, idx){\n      var head = card.querySelector('.ps3-head');\n      if(!head) return;\n      head.addEventListener('click', function(){\n        setActive(idx);\n      });\n    });\n\n    var mobileIO = null;\n    var onScrollDesktop = null;\n\n    function clearHeights(){\n      // kills any old versions that left minHeight/height behind\n      section.style.minHeight = '0px';\n      section.style.height = 'auto';\n    }\n\n    function desktopDriver(){\n      // Tight scroll room per card reveal (no giant tail)\n      var stepPx = 120;   // decrease to 80 if you want even less scroll\n      var buffer = 16;\n\n      function computeHeight(){\n        // clear first so measurements aren't polluted by old values\n        section.style.minHeight = '0px';\n        section.style.height = 'auto';\n\n        var stackH = stack.offsetHeight;\n        var extra = Math.max(0, (steps - 1)) * stepPx;\n\n        // IMPORTANT: set exact height, not minHeight\n        section.style.height = (stackH + extra + buffer) + 'px';\n      }\n\n      function onScroll(){\n        var rect = section.getBoundingClientRect();\n        var vh = window.innerHeight || document.documentElement.clientHeight;\n\n        var total = rect.height - vh;\n        if(total <= 0){\n          setActive(0);\n          return;\n        }\n\n        var passed = 0 - rect.top;\n        var p = passed / total;\n        if(p < 0) p = 0;\n        if(p > 1) p = 1;\n\n        var idx = Math.floor(p * steps);\n        if(idx < 0) idx = 0;\n        if(idx > steps - 1) idx = steps - 1;\n\n        setActive(idx);\n      }\n\n      computeHeight();\n      onScroll();\n\n      window.addEventListener('scroll', onScroll, { passive: true });\n      onScrollDesktop = onScroll;\n\n      window.addEventListener('resize', function(){\n        computeHeight();\n        var activeIdx = cards.findIndex(function(c){ return c.classList.contains('is-active'); });\n        setActive(activeIdx >= 0 ? activeIdx : 0);\n        onScroll();\n      });\n    }\n\n    function mobileDriver(){\n      clearHeights();\n\n      if(mobileIO) mobileIO.disconnect();\n      mobileIO = new IntersectionObserver(function(entries){\n        var best = null;\n        entries.forEach(function(e){\n          if(!e.isIntersecting) return;\n          if(!best || e.intersectionRatio > best.intersectionRatio) best = e;\n        });\n        if(best){\n          var idx = parseInt(best.target.getAttribute('data-i'), 10) || 0;\n          setActive(idx);\n        }\n      }, { threshold: [0.35, 0.55, 0.75] });\n\n      cards.forEach(function(c){ mobileIO.observe(c); });\n    }\n\n    function init(){\n      // remove any leftover height from earlier versions\n      clearHeights();\n\n      setActive(0);\n\n      if(isDesktop()){\n        if(mobileIO) { mobileIO.disconnect(); mobileIO = null; }\n        desktopDriver();\n      } else {\n        mobileDriver();\n      }\n    }\n\n    init();\n  })();\n</script>",
